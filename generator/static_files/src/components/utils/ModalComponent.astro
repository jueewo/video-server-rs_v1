---
import type { CollectionEntry } from "astro:content";

import { Image } from "astro:assets";

interface Props {
  // faqdata: Array<Object>;
  id: String;
  titletxt: String; // default: NONE
  desctxt: String; // default: NONE
  modalbtn: String; // default: OPEN
  closebtn: String; // default: CLOSE
  fullpage: Boolean; // default: false
}
const { id, titletxt, desctxt, modalbtn, closebtn, fullpage } = Astro.props;

// if (!id) id = "fsfd";

// const showimage = false;
---

<div class="flex justify-center items-center m-4">
  <button
    class="btn btn-warning"
    onclick={id ? `${id}.showModal()` : `modal_1.showModal()`}
  >
    {modalbtn ? <span>{modalbtn}</span> : <span>OPEN</span>}

    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-6 h-6"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
    </svg>
  </button>
  <dialog id={id ? id : "modal_1"} class="modal modal-bottom sm:modal-middle">
    <form method="dialog" class="modal-box">
      <!-- <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2"> -->
      <!-- CLOSE BUTTON  x -->
      <!-- https://heroicons.com/ -->
      <button class="z-20 btn btn-circle btn-ghost absolute right-2 top-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-6 h-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"
          >
          </path>
        </svg>
      </button>
      <!-- </button> -->

      {titletxt && <h3 class="font-bold text-lg">{titletxt}</h3>}
      <!-- <h3 class="font-bold text-lg">Hello!</h3> -->
      <!-- <p class="py-4">Press ESC key or click the button below to close</p> -->
      {desctxt && <p class="py-4">{desctxt}</p>}

      <slot />
      <!-- <div class="modal-action">
        <button class="btn">
          {closebtn ? <span>{closebtn}</span> : <span>Close</span>}
        </button>
      </div> -->
    </form>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</div>
