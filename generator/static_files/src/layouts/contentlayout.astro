---
import "../styles/global.css";

import "../styles/prose.css"
import "../styles/toc.css";

import NavFooter from "../components/MyNavFooter.astro";

import CardBlog from "../components/CardBlog.astro";



import Config from "../website.config.cjs";
import Header from "./_header.astro";

// import * as testscript from "../scripts/test.js";

import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";

import FormattedDate from "../components/utils/FormattedDate.astro";
import ProgressRing from "../components/anim/ProgressRing.astro";
import LikeButton from "../components/preact/LikeButtonRemote";
import SurveyRemote from "../components/preact/surveyremote/SurveyRemote";
import { IconEnvelope } from "../components/icons/IconEnvelope";
import ElementRenderer from "../components/page-renderer/ElementRenderer.astro";
import FAQComponent from "../components/FAQComponent.astro";
import ThemeToggle from "../components/utils/ThemeToggle.astro";
import SearchBar from "../components/SearchBar.astro";
import { b } from '../utils/siteBase';




// export interface Props {
//   entry: CollectionEntry["data"];
//   headings: MarkdownHeading[];
//   collection: "";
//   lang: "";
// }

export interface Props {
  entry: any;
  headings: any;
  collection: string;
  lang: string;
}

const { entry, headings, collection } = Astro.props;

const {lang } = Astro.params;

const enablelatex = entry.data.enablelatex;
const enablemermaid = entry.data.enablemermaid;

//.. page_metatags for header
const page_metatags = {
  "title": entry.data.title,
  "description": entry.data.description ? entry.data.description :  entry.data.desc,
  "keywords": entry.data.keywords,
  "author": entry.data.author,
}
const title = entry.data.title;
//..

// import { getRelativeLocaleUrl } from 'astro:i18n';
// const preferredLocale = Astro.preferredLocale;
// // const preferredLocales = Astro.preferredLocaleList;


// const { title, pubDate, updatedDate, heroImage } = Astro.props;

const pageid = lang + '-' + collection + '-' + entry.id.replace(/\.(md|mdx)$/, "");

---



<html lang={lang ? lang : 'en'}>

  <Header title={title} page_metatags={page_metatags} enablelatex={enablelatex} enablemermaid={enablemermaid} />

  <body>
    <ProgressRing/>

    <div class="navbar bg-base-100/90 backdrop-blur-md z-50 sticky top-0 border-b border-base-300/30">
      <div class="navbar-start">
        <a class="btn btn-ghost text-xl uppercase" href={b + "/" + (lang ?? "en") + "/home"}>
          {Config.siteName}
        </a>
      </div>
      <div class="navbar-end">
        <SearchBar lang={lang ?? "en"} searchableCollections={Config.searchableCollections} />
        <ThemeToggle showtext={false} />
      </div>
    </div>

    <div class="drawer">
      { !entry.draft_content && entry.showtoc && (
          <input id="my-drawer-2" type="checkbox" class="drawer-toggle" />
      )}
      <div class="drawer-content flex flex-col items-center justify-center max-w-full overflow-x-hidden px-2 sm:px-4">


          <div class="mt-4 w-full max-w-full px-2 sm:px-0">
            <CardBlog  card={entry} pathdir={collection} disableclick/>
          </div>


        <!-- BREADCRUMBS -->
        <div class="text-sm breadcrumbs max-w-full overflow-x-auto">
          <ul>
            <li>

              <a href={b+'/'+(lang ? lang+'/home' : 'home')}>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                  ></path>
                </svg>
              </a>
            </li>
            <li>

              <a href={b+'/'+(lang ? lang+'/' : '')+collection}>
                {collection[0].toUpperCase() + collection.substring(1)}
              </a>
            </li>

            <li>
              <!-- <span>{entry.slug[0].toUpperCase() + entry.slug.substring(1)}</span> -->
              <span>{entry.data.title}</span>
            </li>
          </ul>
        </div>

        {entry.data.draft_content && (
          <div class="w-3/4 mx-20 mt-20 hero bg-gradient-to-r from-warning to-primary">
            <div class="hero-content text-center">
              <div class="max-w-xl">
                  <h1 class="text-2xl">
                    <!-- xxx: {JSON.stringify(entry.data)} -->
                    {entry.data.draft_content_msg && entry.data.draft_content_msg.length>0 ? (
                    <div>
                      <div>{entry.data.draft_content_msg}</div>
                    </div>
                    ):("under review")}
                  </h1>
                  <h2  class="mt-2 text-lg">
                  {entry.data.draft_content_msg_long && entry.data.draft_content_msg_long.length>0 && (
                    <div>
                      <div>{entry.data.draft_content_msg_long}</div>
                    </div>)
                  }

                  </h2>
              </div>
            </div>
          </div>
        )}
        <!-- TOC  -->
        { !entry.data.draft_content && entry.data.showtoc && (
            <div class="p-5">
              <label
                for="my-drawer-2"
                class="btn btn-primary drawer-button"
              >
                Table of content
              </label>
            </div>
          )
        }

        <!-- elements_above: JSON-driven page elements rendered before prose -->
        {entry.data.elements_above && entry.data.elements_above.length > 0 && (
          <div class="w-full">
            {entry.data.elements_above.map((el: any, i: number) => (
              <ElementRenderer element={el} index={i} lang={lang} />
            ))}
          </div>
        )}

        <!-- slug content / slot -->

        <div class="flex justify-center w-full max-w-[100vw] overflow-x-hidden box-border">
          <div class="prose py-16 px-4 sm:px-6 md:px-8 w-full max-w-[calc(100vw-2rem)] sm:max-w-[calc(100vw-3rem)] md:max-w-prose [&_pre]:max-w-full [&_pre]:overflow-x-auto [&_code]:break-words [&_pre_code]:break-normal">
            <slot />
          </div>
        </div>

        <!-- elements_below: JSON-driven page elements rendered after prose -->
        {entry.data.elements_below && entry.data.elements_below.length > 0 && (
          <div class="w-full">
            {entry.data.elements_below.map((el: any, i: number) => (
              <ElementRenderer element={el} index={i} lang={lang} />
            ))}
          </div>
        )}

        <!-- faqdata: inline FAQ rendered from frontmatter -->
        {entry.data.faqdata && entry.data.faqdata.length > 0 && (
          <div class="w-full max-w-3xl mx-auto px-4 py-8">
            <FAQComponent faqdata={entry.data.faqdata} />
          </div>
        )}



        {Config.datatool &&
        <LikeButton label="Like" showicon url={Config.datatool.url} websiteid={Config.datatool.websiteid} pageid={pageid} token={Config.datatool.token} client:visible />
        }

        {Config.datatool &&
          <>
            <div class="flex justify-center pt-4 ">

              <button class="btn btn-primary" onclick="my_modal_1.showModal()"><IconEnvelope setclass="w-8 h-8"/> Contact & Newsletter</button>
            </div>
            <dialog id="my_modal_1" class="modal">
              <div class="modal-box">
                <h3 class="text-lg font-bold">Hello!</h3>
                <p class="py-4">Press ESC key or click the button below to close</p>
                <SurveyRemote url={Config.datatool.url} surveyid="survey_contact_1" sourceid={"astro-cms-site&contentlayout&"+pageid} title="Please enter your contact data"  submitbuttontxt="Send" thankyoumessage="THANK YOU!" showicon client:only="preact" />

                <div class="modal-action">
                  <form method="dialog">
                    <button class="btn">Close</button>
                  </form>

                </div>
              </div>
            </dialog>
          </>
          }



        <div class="mt-16 text-xs">
          <span class="mr-2">{"|"}</span>
          {
            entry.data.pubDate && (
              <span>
                created on
                <FormattedDate date={entry.data.pubDate} />
              </span>
            )
          }

          { entry.data.updatedDate && (
              <span>
                {entry.data.pubDate && <span class="mx-2">{"|"}</span>}

                <span>
                  updated on
                  <FormattedDate date={entry.data.updatedDate} />
                </span>
              </span>
            )
          }
          <span class="ml-2">{"|"}</span>
        </div>
      </div>

      { !entry.data.draft_content && entry.data.showtoc && (
      <div class="drawer-side">
        <label for="my-drawer-2" class="drawer-overlay"></label>
        <ul class="menu p-4 w-72 h-full bg-base-200 text-base-content">
          {/* <!-- Sidebar content here --> */}

          {/* <!-- CLOSE BUTTON  --> */}
          <label
            for="my-drawer-2"
            class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2"
          >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-6 h-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 18L18 6M6 6l12 12">
                </path>
            </svg>
          </label>




          <div class="text-sm breadcrumbs">
            <ul>
              <li>
                  <a href={b+'/'+(lang ? lang+'/home' : 'home')}>

                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-6 h-6"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                    ></path>
                  </svg>
                </a>
              </li>
              <li>
                <a href={`${b}/` + collection}> {collection[0].toUpperCase() + collection.substring(1)}
                </a>
              </li>

              <!--
                <li>
                  <span>{ course.slug} </span>
                </li>
              -->
            </ul>
          </div>

          {/* <!-- TOC entries (MENU) -->
          <!-- first title --> */}
          <li style="font-weight: bold;">
            <a href={`${b}/${collection}/${entry.id.replace(/\.(md|mdx)$/, "")}#title`}>
              <span class="w-40"> {entry.data.title} </span>
            </a>
          </li>
          { headings.map((heading: any) => (
              <li class={`h${heading.depth} text-xs`}>
                <a href={`${b}/${collection}/${entry.id.replace(/\.(md|mdx)$/, "")}#${heading.slug}`}>
                  <span class="w-40">{heading.text}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      )}
    </div>

    <footer style="position: relativ; bottom: 0em;">
      <NavFooter
        sitename={Config.footerContent.sitename}
        showlogo={true}
        social={Config.socialMedia}
        legal={Config.legal}
        footerNavigationMenu={Config.footerNavigationMenu}
        footerContent={Config.footerContent}
        extprop="  Built by <a class='link' target='_' href='https://yawninghero.com'><i>yh</i></a>"
      />
    </footer>
  </body>
</html>
