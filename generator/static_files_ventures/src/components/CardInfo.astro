---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { b } from '../utils/siteBase';
import CardDraftOverlay from "./CardDraftOverlay.astro";

interface Props {
    card: CollectionEntry;
    pathdir: String;
    pagelang?: String;
    showimage?: boolean;
}
const { card, pathdir, pagelang, showimage = true } = Astro.props;

let [contentlang, slug] = card.id.replace(/\.(md|mdx)$/, "").split("/");
if (!slug) ((slug = contentlang), (contentlang = "en"));
const lang = pagelang || contentlang;
const hasImage = showimage && card.data.image;
---

<a
    href={(!card.data.draft_content || card.data.draft_content_clickable) &&
    (!card.data.url || card.data.url.length == 0)
        ? `${b}/${lang}/${pathdir}/${slug}`
        : card.data.url}
    class="block w-full group"
>
    <div class="w-full max-w-sm mx-auto">
        <div class="card-ventures relative overflow-hidden">
            {hasImage ? (
                <figure class="aspect-[4/3] overflow-hidden">
                    <Image
                        src={card.data.image}
                        alt={card.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        widths={[320, 640, 960]}
                        format="webp"
                        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 384px"
                        quality={80}
                    />
                </figure>
            ) : (
                <div class="aspect-[4/3] bg-gradient-to-br from-surface-alt to-surface-raised flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 text-text-subtle/30">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                    </svg>
                </div>
            )}

            <div class="absolute h-1/2 bottom-0 left-0 right-0 bg-black/80 text-white">
                <div class="p-4 h-full flex flex-col">
                    <span class="flex items-center gap-2">
                        <h2 class="text-base sm:text-lg font-bold font-heading flex-auto line-clamp-2">{card.data.title}</h2>
                        {card.data.badge && (
                            <span class="flex-shrink-0 bg-accent text-xs font-medium px-2 py-0.5 rounded">{card.data.badge}</span>
                        )}
                    </span>
                    <p class="text-sm text-white/80 mt-1 line-clamp-2">{card.data.desc}</p>
                    <div class="mt-auto flex flex-wrap gap-1.5">
                        {card.data.typetags?.slice(0, 3).map((tag: string) => (
                            <span class="text-xs font-medium bg-primary/80 text-white px-2 py-0.5 rounded-full">#{tag}</span>
                        ))}
                        {card.data.tags?.slice(0, 3).map((tag: string) => (
                            <span class="text-xs border border-white/30 text-white/70 px-2 py-0.5 rounded-full">{tag}</span>
                        ))}
                    </div>
                </div>
            </div>

            {card.data.content_msg && (
                <span class="absolute left-3 top-3 bg-accent text-xs font-medium px-2 py-1 rounded-md">{card.data.content_msg}</span>
            )}

            {card.data.draft_content && (
                <div class="absolute inset-0"><CardDraftOverlay card={card} /></div>
            )}
        </div>
    </div>
</a>
