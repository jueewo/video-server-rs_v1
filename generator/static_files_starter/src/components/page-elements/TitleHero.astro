---
import PicFromContent from "../utils/PicFromContent.astro";

const { id, title, desc, desc2, image, img, h1, h2: isH2 } = Astro.props;

const descStr: string = Array.isArray(desc) ? desc.join(' ') : (desc || '');
const desc2Str: string = Array.isArray(desc2) ? desc2.join(' ') : (desc2 || '');
---

<section id={id} class="pt-24 pb-10 px-6">
    <div class="max-w-4xl mx-auto">
        {/* Optional logo/image floated to the side */}
        <div class="flex flex-col lg:flex-row items-start gap-6">
            {(image ?? img) && (
                <div class="flex-shrink-0">
                    <PicFromContent
                        imagePath={image ?? img}
                        altTitle={"image_" + title?.replace(/ /g, '-')}
                        class="w-16 h-16 lg:w-20 lg:h-20 rounded-xl"
                    />
                </div>
            )}
            <div>
                {/* Decorative label */}
                <div class="mb-4 animate-fade-up">
                    <div class="w-8 h-[3px] bg-accent rounded-full"></div>
                </div>

                {h1 ? (
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-extrabold tracking-[-0.04em] leading-[1.05] animate-fade-up delay-1">
                        <span class="gradient-text">{title}</span>
                    </h1>
                ) : isH2 ? (
                    <h2 class="text-3xl md:text-4xl font-display font-bold tracking-[-0.035em] leading-[1.1] text-text animate-fade-up delay-1">{title}</h2>
                ) : (
                    <h3 class="text-2xl md:text-3xl font-display font-bold tracking-[-0.03em] leading-[1.15] text-text animate-fade-up delay-1">{title}</h3>
                )}

                {descStr && (
                    <p class={`mt-4 text-text-muted leading-relaxed animate-fade-up delay-2 ${h1 ? 'text-lg md:text-xl max-w-2xl' : 'max-w-xl'}`}>
                        <Fragment set:html={descStr} />
                    </p>
                )}
                {desc2Str && (
                    <p class="mt-3 text-text-muted leading-relaxed animate-fade-up delay-3">
                        <Fragment set:html={desc2Str} />
                    </p>
                )}
            </div>
        </div>
    </div>
</section>
