---
/**
 * Custom 404 Page
 *
 * This page is automatically served by Astro for any routes that don't exist.
 * It works in both development and production (static) builds.
 */

import "../styles/global.css";
import Config from "../website.config.cjs";

export const prerender = true;

const defaultLang = Config.defaultLanguage?.locale || "en";
---

<html lang={defaultLang}>
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=5"
        />
        <title>404 - Page Not Found | {Config.siteTitle}</title>

        <link rel="icon" type="image/x-icon" href={Config.favicon} />
        <meta name="apple-mobile-web-app-title" content={Config.siteTitle} />
        <link rel="apple-touch-icon" href={Config.siteLogoIconTouch} />

        <meta name="robots" content="noindex, nofollow" />

        <script is:inline>
            if (localStorage.getItem("theme") === null) {
                document.documentElement.setAttribute("data-theme", "light");
            } else {
                document.documentElement.setAttribute(
                    "data-theme",
                    localStorage.getItem("theme"),
                );
            }
        </script>
    </head>

    <body class="min-h-screen flex flex-col">
        <div class="flex-grow flex items-center justify-center">
            <div class="hero min-h-[60vh]">
                <div class="hero-content text-center">
                    <div class="max-w-md">
                        <div
                            class="text-9xl font-bold text-primary opacity-20 select-none"
                        >
                            404
                        </div>
                        <h1 class="text-4xl font-bold -mt-8">Page Not Found</h1>
                        <p class="py-6 text-base-content/70">
                            Sorry, the page you're looking for doesn't exist or
                            has been moved.
                        </p>
                        <div
                            class="flex flex-col sm:flex-row gap-4 justify-center"
                        >
                            <a
                                href={`/${defaultLang}/home`}
                                class="btn btn-primary"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                    class="w-5 h-5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                                    ></path>
                                </svg>
                                Go Home
                            </a>
                            <button
                                onclick="history.back()"
                                class="btn btn-outline"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                    class="w-5 h-5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"
                                    ></path>
                                </svg>
                                Go Back
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="footer footer-center p-4 bg-base-200 text-base-content">
            <div>
                <p>
                    © {new Date().getFullYear()}
                    {Config.siteName || Config.siteTitle}
                </p>
            </div>
        </footer>
    </body>
</html>
