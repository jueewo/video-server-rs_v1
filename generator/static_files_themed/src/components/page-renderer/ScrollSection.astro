---
/**
 * ScrollSection - Clean horizontal scroll with sticky pinning
 * Minimal implementation using Motion's scroll() API
 */

import SectionBackground from "./SectionBackground.astro";

interface ScrollEffectConfig {
    enabled: boolean;
    direction: "left" | "right";
    speed: "slow" | "medium" | "fast";
    type: "horizontal";
}

interface Props {
    config: ScrollEffectConfig;
    bgimage?: string;
    bgimage_alt?: string;
    parallax?: boolean;
    styleclass?: string;
    priorityBg?: boolean;
}

const {
    config,
    bgimage,
    bgimage_alt = "",
    parallax = false,
    styleclass = "",
    priorityBg = false,
} = Astro.props;

const hasBgImage = !!bgimage;
---

<div
    class={"scroll-section " + styleclass}
    data-scroll-config={JSON.stringify(config)}
>
    {
        hasBgImage && (
            <SectionBackground
                bgimage={bgimage}
                bgimage_alt={bgimage_alt}
                parallax={parallax}
                priority={priorityBg}
            />
        )
    }

    <div class="scroll-container">
        <div class="scroll-track">
            <slot />
        </div>
    </div>
</div>

<script>
    import { animate, scroll } from "motion";

    function initHorizontalScroll(section: Element, config: any) {
        if (section.hasAttribute("data-initialized")) return;
        section.setAttribute("data-initialized", "true");

        const track = section.querySelector(".scroll-track") as HTMLElement;
        const items = section.querySelectorAll(".scroll-item");

        if (!track || items.length === 0) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
            return;
        if (window.innerWidth < 768) return;

        // Make AnimateOnView cards visible
        items.forEach((item) => {
            const animWrapper = item.querySelector(
                ".animate-on-view",
            ) as HTMLElement;
            if (animWrapper) animWrapper.style.opacity = "1";
        });

        // Calculate scroll distance
        const distance = (items.length - 1) * 100;

        // Animate with Motion's scroll()
        scroll(
            animate(track, {
                transform: [`translateX(0vw)`, `translateX(-${distance}vw)`],
            }),
            {
                target: section,
                offset: ["start start", "end end"],
            },
        );
    }

    function init() {
        document.querySelectorAll(".scroll-section").forEach((section) => {
            const data = section.getAttribute("data-scroll-config");
            const config = data ? JSON.parse(data) : { enabled: false };
            if (config.enabled) initHorizontalScroll(section, config);
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () =>
            setTimeout(init, 100),
        );
    } else {
        setTimeout(init, 100);
    }

    document.addEventListener("astro:page-load", () => setTimeout(init, 100));
</script>

<style>
    @media (max-width: 767px) {
        .scroll-section {
            overflow-x: hidden;
        }

        .scroll-container {
            position: relative;
            height: auto;
        }

        .scroll-track {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        :global(.scroll-item) {
            width: 100%;
            min-height: 50vh;
        }
    }

    @media (min-width: 768px) {
        .scroll-section {
            height: 300vh;
            position: relative;
            /* IMPORTANT: No overflow hidden on parent of sticky element */
        }

        .scroll-container {
            position: sticky;
            top: 0;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            /* Ensure sticky works */
            z-index: 1;
        }

        .scroll-track {
            display: flex;
            flex-direction: row;
            height: 100%;
            width: max-content; /* ADD THIS - important for horizontal layout */
        }

        :global(.scroll-item) {
            width: 100vw;
            height: 100vh;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        :global(.scroll-item .animate-on-view) {
            opacity: 1 !important;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        :global(.scroll-item .my-12) {
            margin: 0 !important;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .scroll-section {
            height: auto !important;
        }

        .scroll-container {
            position: relative !important;
            height: auto !important;
        }

        .scroll-track {
            flex-direction: column !important;
            gap: 2rem;
        }

        :global(.scroll-item) {
            width: 100% !important;
            height: auto !important;
        }
    }
</style>
