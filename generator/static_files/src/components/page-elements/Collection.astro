import Config from "../../website.config.cjs";
import CardDefault2 from "../CardDefault2.astro";
import CardInfo from "../CardInfo.astro";
import CardBlog from "../CardBlog.astro";
import TitleAlertBanner from "./TitleAlertBanner.astro";

// const {element, alt, index } = Astro.props;
const { element, lang } = Astro.props;

// let showing_default_language = false;
const default_lang = Config.defaultLanguage.locale; // .. "en"

