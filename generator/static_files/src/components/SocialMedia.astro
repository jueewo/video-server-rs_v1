            "https://www.linkedin.com/in/" + handle,
        path: icons["linkedin"],
    },
    slack: {
        url_closure: (handle: string) => "https://www.slack.com/" + handle,
        path: icons["slack"],
    },
    telegram: {
        url_closure: (handle: string) => "https://www.telegram.com/" + handle,
        path: icons["telegram"],
    },
    twitch: {
