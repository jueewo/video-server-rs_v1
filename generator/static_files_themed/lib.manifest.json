  "styling": ["Tailwind CSS v4", "@tailwindcss/typography"],
  "fonts": ["Space Grotesk (headings)", "Inter (body)"],
  "themes": "light/dark via .dark class toggle",
  "elements": [
    "Section", "Hero", "Hero2", "TitleHero", "TitleAlertBanner",
