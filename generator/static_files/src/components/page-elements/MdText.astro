{element.content.mdfile} -->

    <!-- <div>LANG: {actlang}</div> -->

    <!-- fsdjafl {element.image} -->

    <PicFromContent
        imagePath={element.content.image}
        altTitle={element.content.title.replace(/ /g, "-")}
        class="max-w-sm lg:max-w-xl m-auto rounded-lg"
    />

    <div
        id={element.props.id ? element.props.id : "xxx"}
        class="flex justify-center min-w-full"
    >
        <div class="prose py-16 mx-5 md:mx-12">
            {Content && <Content />}
        </div>
    </div>

