---

import Config from "../website.config.cjs";
import { b } from '../utils/siteBase';

interface Props {
  // lang: string;
  title?: string;
  page_metatags?: any;
  enablelatex?: boolean;
  enablemermaid?: boolean;
}

const {lang, slug} = Astro.params;
const {title, page_metatags, enablelatex, enablemermaid} = Astro.props;

---

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5" />

    <!-- Preconnect to external origins -->
    {Config.datatool?.url && <link rel="preconnect" href={Config.datatool.url} />}

    <!-- Self-hosted fonts: Syne (headings) + Outfit (body) — no Google Fonts GDPR issue -->
    <!-- Preload critical latin font files so browser fetches them immediately -->
    <link rel="preload" href={`${b}/fonts/outfit-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${b}/fonts/syne-latin.woff2`} as="font" type="font/woff2" crossorigin />
    <!-- Load font CSS without blocking render; swap to stylesheet once loaded -->
    <link rel="stylesheet" href={`${b}/fonts/google-fonts.css`} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={`${b}/fonts/google-fonts.css`} /></noscript>

    {Config.datatool?.url && <link rel="dns-prefetch" href={Config.datatool.url} />}

    <link rel="icon" type="image/x-icon" href={`${b}${Config.favicon}`} />
    <title>{Config.siteTitle} {title && ' | ' + title}</title>

  <meta name="application-name" content={Config.siteName} />

  <meta name="generator" content=`yhm using ${Astro.generator}` />
  <meta name="mantra" content={Config.siteMantra} />
  <meta name="description" content={Config.siteDescription} />

  <meta name="copyright" content={Config.footerContent.copyright} />

  <slot name="head_metatags" />

  <!--  -->
  {page_metatags && <title>{page_metatags.title}</title>}
  {page_metatags && Object.keys(page_metatags).map((key) => (
    <meta name={key} content={page_metatags[key]} slot="head_metatags"/>
  ))}

  <meta name="apple-mobile-web-app-title" content={Config.siteTitle} />
  <link rel="apple-touch-icon" href={`${b}${Config.siteLogoIconTouch}`} />

  <link rel="sitemap" href={`${b}/sitemap-index.xml`} />

  <slot name="head" />

  <!-- <ViewTransitions /> -->

  {enablelatex && (
    <link
      rel="stylesheet"
      href={`${b}/vendor/katex/katex.min.css`}
    />
    <script
      defer
      is:inline
      src={`${b}/vendor/katex/katex.min.js`}
    ></script>
    <script
      defer
      is:inline
      src={`${b}/vendor/katex/contrib/auto-render.min.js`}
      onload="renderMathInElement(document.body);"
    ></script>
  )}

  {enablemermaid && (
    <script is:inline src={`${b}/vendor/mermaid/mermaid.min.js`}></script>
    <script is:inline>
      (function() {
        var darkThemes = ["synthwave", "business", "dark", "night", "dracula", "coffee", "halloween", "forest", "black", "luxury"];

        function getMermaidTheme() {
          var current = document.documentElement.getAttribute("data-theme") || "";
          return darkThemes.includes(current) ? "dark" : "default";
        }

        function renderMermaid() {
          document.querySelectorAll("pre.mermaid").forEach(function(el) {
            if (!el.hasAttribute("data-src")) {
              el.setAttribute("data-src", el.textContent.trim());
            }
            el.textContent = el.getAttribute("data-src");
            el.removeAttribute("data-processed");
          });
          mermaid.initialize({ startOnLoad: false, theme: getMermaidTheme() });
          mermaid.run();
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", renderMermaid);
        } else {
          renderMermaid();
        }

        var observer = new MutationObserver(renderMermaid);
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
      })();
    </script>
  )}

  <script is:inline define:vars={{ themelight: Config.themelight, themedark: Config.themedark }}>
    // Theme initialization - runs inline to prevent flash
    (function() {
      const lightTheme = themelight || "corporate";
      const darkTheme = themedark || "business";
      const savedTheme = localStorage.getItem("theme");

      if (savedTheme === lightTheme || savedTheme === darkTheme) {
        document.documentElement.setAttribute("data-theme", savedTheme);
      } else {
        document.documentElement.setAttribute("data-theme", lightTheme);
        localStorage.setItem("theme", lightTheme);
      }
    })();
  </script>

</head>
