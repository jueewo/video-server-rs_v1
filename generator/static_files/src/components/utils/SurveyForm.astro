<script>
  


const tabs = document.querySelectorAll(".steps");
const tab = document.querySelectorAll(".step");
const panel = document.querySelectorAll(".panel");
const page = document.querySelectorAll(".page");

const validation_message = document.getElementById("validation_message");
const back_button = document.getElementById("backbtn");
const next_button = document.getElementById("nextbtn");

back_button?.setAttribute("disabled", "true");


function validateEmail(email) {
  const res = /^[\w-\.]+@([\w-]+\.)+[\w-]{2,10}$/;

  console.log("Validate Email: "+email);
  console.log(res.test(String(email).toLowerCase()));

  return res.test(String(email).toLowerCase());
}

function onTabClick(event) {

  var valid_page = true;

  console.log("VALIDATE")
  for (let i = 0; i < tab.length; i++) {
    if (tab[i].classList.contains("active")) {
      console.log("Active was : " + i);
      console.log("...VALIDATE...")
      let inputelements = page[i].getElementsByTagName("input");

      
      
      for (let j=0; j<inputelements.length; j++) {
        console.log(">> "+inputelements[j].value + ">> "+inputelements[j].name +  ">> "+inputelements[j].checked + " | " + inputelements[j].required )
        console.log("xxx "+inputelements[j].type)

        var valid_element = true;

        if (inputelements[j].required) {

          if (inputelements[j].required &&  (inputelements[j].type == "text")) {
            console.log(">> eval >> "+ String(inputelements[j].value.length>0))
            valid_element = inputelements[j].value.length>0;
            // if (inputelements[j].value.length == 0) {
            //   inputelements[j].classList.add('failed')
            // }
          }
          if (inputelements[j].type == "email") {
            console.log(">> eval email >> "+ validateEmail(inputelements[j].value))
            valid_element = validateEmail(inputelements[j].value);
            // if (inputelements[j].value) {
            //   inputelements[j].classList.add('failed')
            // }
          }

          if (inputelements[j].required && inputelements[j].type =="checkbox") {
            console.log(">> eval checked >> "+inputelements[j].checked)
            valid_element = inputelements[j].checked
          }

          if (!valid_element) {
            inputelements[j].classList.add('failed')
            valid_page = false;
          }

        }
        
      }


      let textareaelements = page[i].getElementsByTagName("textarea");
      for (let j=0; j<textareaelements.length; j++) {
        // console.log(">>> "+textareaelements[j].value + " | "+textareaelements[j].required)
        if (textareaelements[j].required) {
          console.log(">> eval >> "+textareaelements[j].value)
        }
      }
    };
  }

  if (!valid_page) {
    validation_message.innerHTML = "NOT VALID";
    return;
  } else {
    validation_message.innerHTML = "";
  }

  // deactivate existing active tabs and panel
  for (let i = 0; i < tab.length; i++) {
    tab[i].classList.remove("active");
  }

  for (let i = 0; i < panel.length; i++) {
    panel[i].classList.remove("active");
    page[i].classList.remove("active");
  }


  // activate new tabs and panel
  event.target.classList.add('active');
  event.target.classList.add('step-primary');
  let classString = event.target.getAttribute('data-target');
  console.log(classString);
  
  document.getElementById('panels').getElementsByClassName(classString)[0].classList.add("active");
  document.getElementById('pages').getElementsByClassName(classString)[0].classList.add("active");

} //..end function onTabClick

function onBack(event) {

  console.log("back..")
  var act_page = 0;

  if (next_button) {
    next_button.removeAttribute("disabled");
    // console.log("SET next_button ENABLED")
  }
  

  // find active tabs and panel
  for (let i = 0; i < tab.length; i++) {
    if (tab[i].classList.contains("active")) {
      act_page = i;
    };
  }
  if (act_page>0) {

    if (act_page == 1) {
      // event.target.innerHTML = "START";
      event.target.setAttribute("disabled", true);
    }

    // deactivate existing active tabs and panel
    for (let i = 0; i < tab.length; i++) {
      tab[i].classList.remove("active");
    }

    for (let i = 0; i < panel.length; i++) {
      panel[i].classList.remove("active");
      page[i].classList.remove("active");
    }

    tab[act_page-1].classList.add("active");
    tab[act_page-1].classList.add("step-primary");
    panel[act_page-1].classList.add("active");
    page[act_page-1].classList.add("active");
  }
}

function onNext(event) {

  console.log("next..")
  var act_page = 0;

  if (back_button) {
    back_button.removeAttribute("disabled");
    // console.log("SET back_button ENABLED")
  }

  // find active tabs and panel
  for (let i = 0; i < tab.length; i++) {
    if (tab[i].classList.contains("active")) {
      act_page = i;
    };
  }

  
  // console.log(">> "+act_page+" | "+page.length);
  if (act_page < (page.length-1)) {

    if (act_page == (page.length-2)) {
      // event.target.innerHTML = "END";
      event.target.setAttribute("disabled", true);
    }

    // deactivate existing active tabs and panel
    for (let i = 0; i < tab.length; i++) {
      tab[i].classList.remove("active");
    }

    for (let i = 0; i < panel.length; i++) {
      panel[i].classList.remove("active");
      page[i].classList.remove("active");
    }

  
    tab[act_page+1].classList.add("active");
    tab[act_page+1].classList.add("step-primary");
    panel[act_page+1].classList.add("active");
    page[act_page+1].classList.add("active");
  }

}

// -- add EventListener ---

for (let i = 0; i < tab.length; i++) {
  tab[i].addEventListener('click', onTabClick, false);
}

back_button?.addEventListener('click', onBack, false);
next_button?.addEventListener('click', onNext, false);


// var navItems = document.querySelectorAll(".step");
// for (var i = 0; i < navItems.length; i++) {
//    navItems[i].addEventListener("click", function(ev) {
//       this.classList.add("step-primary");
      
//       // console.log("add active to > "+JSON.stringify(ev.target))
//    });
// }

</script> 

