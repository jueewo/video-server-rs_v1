        path: icons["twitch"],
    },
    twitter: {
        url_closure: (handle: string) => "https://www.twitter.com/" + handle,
        path: icons["twitter"],
    },
    x: {
        url_closure: (handle: string) => "https://www.x.com/" + handle,
        path: icons["x"],
        size: 24,
    },
    whatsapp: {
        url_closure: (handle: string) => "https://www.whatsapp.com/" + handle,
        path: icons["whatsapp"],
    },
    youtube: {
        url_closure: (handle: string) => "https://www.youtube.com/" + handle,
        path: icons["youtube"],
    },
    home: {
        url_closure: (handle: string) => baseURL + "/" + handle,
        path: icons["home"],
    },
};
---

<div class="flex items-center gap-1 md:gap-2 lg:gap-3">
    {
        socialMedia &&
            socialMedia.map((sm) => {
                const platformData = smdata[sm.name] ?? smdata["default"];
                const viewBoxSize = platformData.size ?? 16;
                const viewBox = `0 0 ${viewBoxSize} ${viewBoxSize}`;
                const url = platformData.url_closure(sm.handle);

                return (
                    <div class="items-center">
                        <a
                            class="px-1 md:px-2 lg:px-3 text-base-content/70 hover:text-primary transition-colors"
                            href={url}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={sm.name}
                        >
                            <svg
                                class="fill-current"
                                viewBox={viewBox}
                                xmlns="http://www.w3.org/2000/svg"
                                width={setwidth}
                                height={setheight}
                            >
                                {platformData.path.map((pathData) => (
                                    <path d={pathData} />
                                ))}
                            </svg>
                        </a>
                    </div>
                );
            })
    }
</div>
