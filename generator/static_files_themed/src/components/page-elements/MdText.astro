---
import { getEntry, render } from "astro:content";
import PicFromContent from "../utils/PicFromContent.astro";

const { element, alt, index, lang } = Astro.props;

const actlang = lang || "en";
const mdcollslug = element.mdcollslug ?? element.content?.mdcollslug;
const fullscreen = element.fullscreen ?? element.props?.fullscreen;
const elId = element.id ?? element.props?.id;
const image = element.image ?? element.content?.image;
const title = element.title ?? element.content?.title ?? "";

const md_content = await getEntry("mdcontent", `${actlang}/${mdcollslug}`);
const { Content, headings } = md_content
    ? await render(md_content)
    : { Content: null, headings: null };
---

<section class={(fullscreen ? "min-h-screen " : "") + "py-12 md:py-20 px-4 bg-surface-alt"}>
    {image && (
        <PicFromContent
            imagePath={image}
            altTitle={title.replace(/ /g, "-")}
            class="max-w-sm lg:max-w-xl mx-auto rounded-xl mb-8"
        />
    )}

    <div id={elId ?? "mdtext"} class="flex justify-center">
        <div class="prose max-w-3xl py-8 px-4 md:px-8">
            {Content && <Content />}
        </div>
    </div>
</section>
