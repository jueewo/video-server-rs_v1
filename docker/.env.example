# ============================================================
# Media Server — Docker / Podman deployment environment
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Harbor image registry
# Set this to pull a pre-built image from your Harbor registry.
# Leave unset (or comment out) to build from source locally.
#
# Example: harbor.example.com/media-server/app:latest
# The image is built and pushed by the Forgejo CI pipeline or
# manually with docker/build-push.sh
# ------------------------------------------------------------
MEDIA_SERVER_IMAGE=harbor.example.com/media-server/app:latest

# ------------------------------------------------------------
# Domain — used by Caddy for automatic HTTPS (Let's Encrypt)
# Must have a DNS A record pointing at this server.
# ------------------------------------------------------------
DOMAIN=app.example.com

# ------------------------------------------------------------
# OIDC — point at your central Casdoor instance
# Create an Application in Casdoor and copy the credentials here.
# Redirect URL to register in Casdoor: https://<DOMAIN>/auth/callback
#
# Using local Casdoor (docker-compose.casdoor.yml override)?
#   Set OIDC_ISSUER_URL=http://casdoor:8000
#   and add AUTH_DOMAIN=auth.example.com for Caddy to proxy it.
# ------------------------------------------------------------
OIDC_ISSUER_URL=https://auth.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ------------------------------------------------------------
# Platform admin
# Your Casdoor user UUID — visible at /profile under "User ID"
# Grants access to /admin and tenant management.
# ------------------------------------------------------------
PLATFORM_ADMIN_ID=

# ------------------------------------------------------------
# RTMP stream publishing token
# Required by MediaMTX to authorise incoming RTMP publish requests.
# Generate a strong random value: openssl rand -base64 32
# ------------------------------------------------------------
RTMP_PUBLISH_TOKEN=changeme

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
RUST_LOG=info
RUN_MODE=production

# Session cookies — set to true when running behind HTTPS (recommended in production)
SESSION_SECURE=true

# Docs viewer root directory
DOCS_ROOT=docs

# Dev-only routes — NEVER enable in production
ENABLE_DEV_ROUTES=false

# ------------------------------------------------------------
# Rate limiting
# ------------------------------------------------------------
RATE_LIMIT_ENABLED=true

# Auth endpoints (login, OIDC)
RATE_LIMIT_AUTH_RPM=10
RATE_LIMIT_AUTH_BURST=5

# Upload endpoints
RATE_LIMIT_UPLOAD_RPM=15
RATE_LIMIT_UPLOAD_BURST=5

# Media serving (gallery / playback)
RATE_LIMIT_MEDIA_SERVING_RPM=2000
RATE_LIMIT_MEDIA_SERVING_BURST=500

# Access code / token validation
RATE_LIMIT_VALIDATION_RPM=20
RATE_LIMIT_VALIDATION_BURST=10

# API mutation (create / update / delete)
RATE_LIMIT_API_MUTATE_RPM=30
RATE_LIMIT_API_MUTATE_BURST=10

# General endpoints
RATE_LIMIT_GENERAL_RPM=120
RATE_LIMIT_GENERAL_BURST=30

# ------------------------------------------------------------
# Grafana admin password
# ------------------------------------------------------------
GRAFANA_PASSWORD=changeme

# ------------------------------------------------------------
# Emergency login — for initial setup or OIDC recovery only
# Disable in normal production use.
# ------------------------------------------------------------
# ENABLE_EMERGENCY_LOGIN=true
# SU_USER=admin
# SU_PWD=changeme

# Site Generator — path inside the container to the static site components
# These are copied into the image from generator/static_files/
SITE_COMPONENTS_DIR=/app/generator/static_files
