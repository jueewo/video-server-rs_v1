# ============================================================
# Standalone deployment — simplified environment
# Copy this file to .env:  cp .env.standalone.example .env
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
RUST_LOG=info

# Set to "development" to skip security checks during testing
RUN_MODE=production

# HTTP port — change if 3000 is taken
HTTP_PORT=3000

# ------------------------------------------------------------
# OIDC authentication
# Point at your identity provider (Keycloak, Casdoor, etc.)
# Uncomment and fill in when ready.
# ------------------------------------------------------------
# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=platform
# OIDC_CLIENT_SECRET=changeme
# OIDC_REDIRECT_URL=http://localhost:3000/auth/callback

# ------------------------------------------------------------
# Emergency login — for initial setup or when OIDC is not configured
# Disable in production once OIDC is working.
# ------------------------------------------------------------
ENABLE_EMERGENCY_LOGIN=true
SU_USER=admin
SU_PWD=changeme

# ------------------------------------------------------------
# RTMP streaming token (only needed if using live streaming)
# Generate a strong value:  openssl rand -base64 32
# ------------------------------------------------------------
RTMP_PUBLISH_TOKEN=changeme
