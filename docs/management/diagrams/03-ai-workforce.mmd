        SUP --> SEO["🔍 SEO Optimizer<br/><small>autonomy: autonomous<br/>model: claude-haiku<br/>tools: read, search</small>"]
        SUP --> CP["📋 Course Planner<br/><small>autonomy: supervised<br/>model: claude-sonnet<br/>tools: read, write, list</small>"]
        SUP --> PA["📐 Process Analyst<br/><small>autonomy: manual<br/>model: gpt-4o<br/>tools: read, search</small>"]
