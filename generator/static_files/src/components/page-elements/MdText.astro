---
// import TitleAlertBanner from "./TitleAlertBanner.astro";
import { getCollection, getEntry, render } from "astro:content";

import PicFromContent from "../utils/PicFromContent.astro";

const { element, alt, index, lang } = Astro.props;

const actlang = lang || "en";
const mdcollslug = element.content.mdcollslug;

const md_content = await getEntry("mdcontent", `${actlang}/${mdcollslug}`);
// const Content = null;

const { Content, headings } = md_content
    ? await render(md_content)
    : { Content: null, headings: null };
---

<div
    class={(element.props && element.props.fullscreen ? "min-h-screen " : "") +
        " bg-base-200 my-12 p-4 md:p-12 lg:full"}
>
