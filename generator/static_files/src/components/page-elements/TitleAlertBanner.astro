---
const { title, desc, desc2 } = Astro.props;

// Normalize desc: JSON may store it as a string or array of strings
const descStr: string = Array.isArray(desc) ? desc.join(' ') : (desc || '');
const desc2Str: string = Array.isArray(desc2) ? desc2.join(' ') : (desc2 || '');
---

<div class="py-5">
  <div class="alert alert-warning">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
    <div class="flex flex-col items-start justify-center">
      <span>{title}</span>
      {descStr && <span><Fragment set:html={descStr} /></span>}
      {desc2Str && <span><Fragment set:html={desc2Str} /></span>}
    </div>
  </div>
</div>