---
import "../styles/global.css";

// import MyMenuSideBarMobile from "../components/MyMenuSideBarMobile.vue";
// import NavFooter from "../components/NavMyFooter.vue";
// import ThemeSwap from "../components/ThemeSwap.astro";

import Config from "../website.config.cjs";

// const { title, description } = Astro.props;
const { lang } = Astro.params;
---

<html lang={lang ? lang : "en"}>
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=5"
        />

        <link rel="icon" type="image/x-icon" href={Config.favicon} />

        <meta name="apple-mobile-web-app-title" content={Config.siteTitle} />
        <link rel="apple-touch-icon" href={Config.siteLogoIcon} />
        <slot name="head" />

        <script is:inline>
            // ☝️ This script prevent the FART effect.
            if (localStorage.getItem("theme") === null) {
                document.documentElement.setAttribute("data-theme", "light");
            } else
                document.documentElement.setAttribute(
                    "data-theme",
                    localStorage.getItem("theme"),
                );
        </script>
    </head>
    <body>
        LANG {lang}
        <div class="hero">
            <div class="flex justify-center">
                <div class="prose py-16 mx-5 md:mx-12">
                    <slot />
                </div>
            </div>
        </div>
    </body>
</html>
