---
import { IconUsers } from "../icons/IconUsers.tsx";
import { IconHeart } from "../icons/IconHeart.tsx";
import { IconBriefcase } from "../icons/IconBriefcase.tsx";
import { IconSearch } from "../icons/IconSearch.tsx";
import { IconMap } from "../icons/IconMap.tsx";

const { id, dataid, data } = Astro.props;

const iconMap: Record<string, any> = {
    users: IconUsers,
    briefcase: IconBriefcase,
    heart: IconHeart,
    search: IconSearch,
    map: IconMap,
};
---

<section class="py-20 px-6 md:px-8 lg:px-12 bg-surface-alt">
    <div id={id} class="max-w-6xl mx-auto">
        <div class="flex flex-wrap justify-center">
            {data && data.length > 0 && data.map((stat: any, idx: number) => (
                <div class={
                    "flex-1 min-w-[140px] max-w-[220px] px-6 py-8 text-center " +
                    (idx < data.length - 1 ? "border-r border-border-strong " : "")
                }>
                    {/* Accent bar — centered above each stat */}
                    <div class="flex justify-center mb-5">
                        <div class="w-10 h-[3px] bg-primary rounded-full"></div>
                    </div>

                    <div class="text-3xl md:text-4xl font-heading font-bold tracking-tight text-primary tabular-nums">
                        {stat.value}
                    </div>
                    <div class="text-[0.6875rem] font-bold uppercase tracking-[0.1em] text-text-subtle mt-2 font-heading">
                        {stat.title}
                    </div>
                    {stat.desc && (
                        <div class="text-sm text-text-muted mt-2 leading-relaxed">{stat.desc}</div>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>
