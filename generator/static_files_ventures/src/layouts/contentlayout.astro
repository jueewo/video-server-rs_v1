---
import "../styles/global.css";
import "../styles/prose.css";
import "../styles/toc.css";

import NavFooter from "../components/MyNavFooter.astro";
import CardBlog from "../components/CardBlog.astro";
import Config from "../website.config.cjs";
import Header from "./_header.astro";

import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";

import FormattedDate from "../components/utils/FormattedDate.astro";
import LikeButton from "../components/preact/LikeButtonRemote";
import SurveyRemote from "../components/preact/surveyremote/SurveyRemote";
import { IconEnvelope } from "../components/icons/IconEnvelope";
import ElementRenderer from "../components/page-renderer/ElementRenderer.astro";
import FAQComponent from "../components/FAQComponent.astro";
import ThemeToggle from "../components/utils/ThemeToggle.astro";
import SearchBar from "../components/SearchBar.astro";
import { b } from '../utils/siteBase';

export interface Props {
  entry: any;
  headings: any;
  collection: string;
  lang: string;
}

const { entry, headings, collection } = Astro.props;
const { lang } = Astro.params;

const enablelatex = entry.data.enablelatex;
const enablemermaid = entry.data.enablemermaid;

const page_metatags = {
  "title": entry.data.title,
  "description": entry.data.description ? entry.data.description : entry.data.desc,
  "keywords": entry.data.keywords,
  "author": entry.data.author,
}
const title = entry.data.title;

const entrySlug = entry.id.replace(/\.(md|mdx)$/, "").split("/").slice(1).join("-");
const pageid = lang + '-' + collection + '-' + entrySlug;
---

<html lang={lang ? lang : 'en'}>

  <Header title={title} page_metatags={page_metatags} enablelatex={enablelatex} enablemermaid={enablemermaid} />

  <body class="min-h-screen bg-surface text-text">

    <!-- ─── Primary top accent stripe ─────────────────── -->
    <div class="fixed top-0 left-0 right-0 z-[51] h-[3px] bg-gradient-to-r from-primary via-primary to-accent"></div>

    <!-- ─── Full-width navbar (content pages) ────────────── -->
    <header class="fixed top-[3px] left-0 right-0 z-50 glass-ventures border-b border-border">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <nav class="flex items-center justify-between h-12">
          <a href={b + "/" + (lang ?? "en") + "/home"} class="font-heading font-bold text-sm tracking-wide text-text hover:text-primary transition-colors uppercase">
            {Config.siteName}
          </a>
          <div class="flex items-center gap-1">
            <SearchBar lang={lang ?? "en"} searchableCollections={Config.searchableCollections} />
            <ThemeToggle />
          </div>
        </nav>
      </div>
    </header>

    <div class="pt-[51px]">
      <div class="flex flex-col items-center justify-center max-w-4xl mx-auto w-full px-4 sm:px-6 lg:px-8">

          <div class="mt-4 w-full">
            <CardBlog card={entry} pathdir={collection} disableclick />
          </div>

          <!-- Breadcrumbs -->
          <nav class="py-4 max-w-full overflow-x-auto" aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 text-text-subtle text-xs font-heading font-medium tracking-wide uppercase">
              <li>
                <a href={b+'/'+(lang ? lang+'/home' : 'home')} class="hover:text-primary transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                  </svg>
                </a>
              </li>
              <li class="text-border-strong">/</li>
              <li>
                <a href={b+'/'+(lang ? lang+'/' : '')+collection} class="hover:text-primary transition-colors">
                  {collection}
                </a>
              </li>
              <li class="text-border-strong">/</li>
              <li class="text-text truncate max-w-[200px] normal-case">{entry.data.title}</li>
            </ol>
          </nav>

          {entry.data.draft_content && (
            <div class="w-3/4 mx-auto mt-10 p-8 rounded-lg bg-primary text-white text-center">
              <h1 class="text-2xl font-heading font-bold">
                {entry.data.draft_content_msg && entry.data.draft_content_msg.length > 0
                  ? entry.data.draft_content_msg
                  : "Under review"}
              </h1>
              {entry.data.draft_content_msg_long && entry.data.draft_content_msg_long.length > 0 && (
                <p class="mt-2 text-lg opacity-90">{entry.data.draft_content_msg_long}</p>
              )}
            </div>
          )}

          <!-- TOC toggle -->
          {!entry.data.draft_content && entry.data.showtoc && (
            <div class="p-5">
              <button id="toc-toggle" class="btn-ventures btn-secondary-ventures text-sm">Table of Contents</button>
            </div>
          )}

          <!-- elements_above -->
          {entry.data.elements_above && entry.data.elements_above.length > 0 && (
            <div class="w-full">
              {entry.data.elements_above.map((el: any, i: number) => (
                <ElementRenderer element={el} index={i} lang={lang} />
              ))}
            </div>
          )}

          <!-- Content -->
          <div class="w-full">
            <div class="prose py-16 w-full max-w-none [&_pre]:max-w-full [&_pre]:overflow-x-auto [&_code]:break-words [&_pre_code]:break-normal">
              <slot />
            </div>
          </div>

          <!-- elements_below -->
          {entry.data.elements_below && entry.data.elements_below.length > 0 && (
            <div class="w-full">
              {entry.data.elements_below.map((el: any, i: number) => (
                <ElementRenderer element={el} index={i} lang={lang} />
              ))}
            </div>
          )}

          <!-- FAQ -->
          {entry.data.faqdata && entry.data.faqdata.length > 0 && (
            <div class="w-full max-w-3xl mx-auto px-4 py-8">
              <FAQComponent faqdata={entry.data.faqdata} />
            </div>
          )}

          {Config.datatool && (
            <LikeButton label="Like" showicon url={Config.datatool.url} websiteid={Config.datatool.websiteid} pageid={pageid} token={Config.datatool.token} client:visible />
          )}

          {Config.datatool && (
            <>
              <div class="flex justify-center pt-4">
                <button id="contact-modal-btn" class="btn-ventures btn-accent-ventures text-sm"><IconEnvelope setclass="w-5 h-5" /> Contact & Newsletter</button>
              </div>
              <dialog id="contact-modal" class="fixed inset-0 z-[70] m-auto bg-surface border border-border rounded-lg shadow-2xl max-w-lg w-full p-6 backdrop:bg-surface-invert/40 backdrop:backdrop-blur-sm">
                <div class="flex justify-between items-center mb-4">
                  <h3 class="text-lg font-heading font-semibold">Get in touch</h3>
                  <form method="dialog"><button class="p-1.5 rounded hover:bg-surface-alt transition-colors text-text-muted">✕</button></form>
                </div>
                <SurveyRemote url={Config.datatool.url} surveyid="survey_contact_1" sourceid={"astro-cms-site&contentlayout&"+pageid} title="Please enter your contact data" submitbuttontxt="Send" thankyoumessage="THANK YOU!" showicon client:only="preact" />
                <div class="mt-4 flex justify-end">
                  <form method="dialog"><button class="btn-ventures btn-secondary-ventures text-sm">Close</button></form>
                </div>
              </dialog>
              <script>
                document.getElementById('contact-modal-btn')?.addEventListener('click', () => {
                  (document.getElementById('contact-modal') as HTMLDialogElement)?.showModal();
                });
              </script>
            </>
          )}

          <!-- Date metadata -->
          <div class="mt-16 mb-8 flex items-center gap-3 text-xs text-text-subtle font-heading tracking-wide">
            <div class="accent-bar"></div>
            {entry.data.pubDate && (
              <span>Published <FormattedDate date={entry.data.pubDate} /></span>
            )}
            {entry.data.updatedDate && (
              <>
                <span class="text-border-strong">·</span>
                <span>Updated <FormattedDate date={entry.data.updatedDate} /></span>
              </>
            )}
          </div>
      </div>
    </div>

    <!-- TOC sidebar -->
    {!entry.data.draft_content && entry.data.showtoc && headings && (
      <div id="toc-panel" class="fixed right-0 top-12 h-[calc(100vh-3rem)] w-64 bg-surface/95 backdrop-blur-md border-l border-border transform translate-x-full transition-transform duration-300 z-40 overflow-y-auto p-5">
        <div class="space-y-0.5">
          <div class="accent-bar mb-3"></div>
          <div class="text-[0.6875rem] font-bold uppercase tracking-[0.1em] text-text-subtle mb-3">On this page</div>
          <a href="#" class="block py-1.5 text-sm font-semibold text-text hover:text-primary transition-colors truncate">{entry.data.title}</a>
          {headings.map((heading: any) => (
            <a href={`#${heading.slug}`} class={`block py-1 text-text-muted hover:text-primary transition-colors truncate ${heading.depth > 2 ? 'pl-4 text-xs' : 'pl-2 text-sm'}`}>
              {heading.text}
            </a>
          ))}
        </div>
      </div>
    )}

    <footer>
      <NavFooter
        sitename={Config.footerContent.sitename}
        showlogo={true}
        social={Config.socialMedia}
        legal={Config.legal}
        footerNavigationMenu={Config.footerNavigationMenu}
        footerContent={Config.footerContent}
        extprop={`Built by <a class='link-editorial text-primary' target='_blank' href='https://yawninghero.com'><i>yh</i></a>`}
      />
    </footer>

    <script>
      const tocToggle = document.getElementById('toc-toggle');
      const tocPanel = document.getElementById('toc-panel');
      if (tocToggle && tocPanel) {
        tocToggle.addEventListener('click', () => {
          tocPanel.classList.toggle('translate-x-full');
        });
      }
    </script>
  </body>
</html>
