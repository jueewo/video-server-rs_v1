---
import { getCollection } from "astro:content";
import Config from "../../website.config.cjs";
import CardDefault2 from "../CardDefault2.astro";
import CardInfo from "../CardInfo.astro";
import CardBlog from "../CardBlog.astro";
import TitleAlertBanner from "./TitleAlertBanner.astro";

const { element, lang } = Astro.props;
const default_lang = Config.defaultLanguage.locale;
const _props = (k: string) => element[k] ?? element.props?.[k];

var filter_by_featured = _props("filter_by_featured");
var filter_featured = _props("filter_featured");
var filter_filtertag = _props("filter_filtertag");
var filter_by_filtertag = filter_filtertag && filter_filtertag.length > 0;
const show_filters = _props("show_filters");

const collection_carddata = (await getCollection(_props("collection")))
    .filter((a) =>
        !a.data.draft &&
        (!filter_by_featured || a.data.featured == filter_featured) &&
        (!filter_by_filtertag ||
            (filter_by_filtertag &&
                a.data.filtertags &&
                a.data.filtertags.includes(filter_filtertag)))
    )
    .sort((a, b) =>
        b.data.pubDate && a.data.pubDate
            ? b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
            : 0
    )
    .sort((a, b) => {
        if (a.data.featured && !b.data.featured) return -1;
        if (!a.data.featured && b.data.featured) return 1;
        return 0;
    })
    .sort((a, b) => a.data.draft_content - b.data.draft_content);

const collection_carddata_actlang = collection_carddata.filter(
    (a) => a.id.split("/")[0] == lang,
);

const show_default_lang = _props("show_default_lang");
const just_unique = _props("just_unique");
const collection_name = _props("collection");

let collection_carddata_defaultlang = [];
if (show_default_lang) {
    collection_carddata_defaultlang = collection_carddata.filter(
        (a) => a.id.split("/")[0] == default_lang,
    );
    if (just_unique) {
        const actlang_ids = collection_carddata_actlang.map(
            (obj) => obj.id.replace(/\.(md|mdx)$/, "").split("/")[1],
        );
        collection_carddata_defaultlang = collection_carddata_defaultlang.filter(
            (a) =>
                a.id.split("/")[0] == default_lang &&
                !actlang_ids.includes(a.id.replace(/\.(md|mdx)$/, "").split("/")[1]),
        );
    }
}

// Collect all unique filtertags for the filter UI
const allFilterTags: string[] = [];
if (show_filters) {
    const tagSet = new Set<string>();
    [...collection_carddata_actlang, ...collection_carddata_defaultlang].forEach((card) => {
        card.data.filtertags?.forEach((tag: string) => tagSet.add(tag));
    });
    // Remove generic "course" tag — not useful as a filter
    tagSet.delete("course");
    allFilterTags.push(...Array.from(tagSet).sort());
}

// Human-readable labels for filtertags
const tagLabels: Record<string, string> = {
    // Academy categories
    "processes": "Processes",
    "ai-data": "AI & Data",
    "operations": "Operations & Planning",
    "digitalization": "Digitalization",
    "rust": "Rust",
    // Blog categories
    "ai": "AI",
    "simulation": "Simulation",
    "crypto": "Crypto",
    "academy": "Academy",
    "general": "General",
};
---

{_props("title") && _props("title").length > 0 && (
    <div class="mt-12 text-center">
        <h2 class="text-3xl font-bold font-heading">{_props("title")}</h2>
    </div>
)}

{show_filters && allFilterTags.length > 0 && (
    <div class="collection-filter mt-8 flex flex-wrap justify-center gap-2 px-4 max-w-5xl mx-auto">
        <button
            class="filter-chip active text-sm font-medium px-3 py-1.5 rounded-full border border-primary bg-primary text-white transition-colors cursor-pointer"
            data-filter="all"
        >
            All
        </button>
        {allFilterTags.map((tag) => (
            <button
                class="filter-chip text-sm font-medium px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-colors cursor-pointer"
                data-filter={tag}
            >
                {tagLabels[tag] || tag}
            </button>
        ))}
    </div>
)}

{(!_props("card") || _props("card") === "default") && (
    <>
        <div class="collection-grid mt-12 grid justify-items-center grid-cols-1 gap-8 px-4 md:px-10 md:gap-10 md:grid-cols-2 xl:gap-8 xl:grid-cols-3 xl:px-5 max-w-7xl mx-auto">
            {collection_carddata_actlang.map((card) => (
                <div class="collection-card w-full" data-filtertags={card.data.filtertags?.join(",") || ""}>
                    {card.data.featured && (
                        <CardDefault2 card={card} pathdir={collection_name} pagelang={lang} />
                    )}
                    {!card.data.featured && (
                        <CardInfo card={card} pathdir={collection_name} pagelang={lang} />
                    )}
                </div>
            ))}
        </div>

        {collection_carddata_defaultlang.length > 0 && (
            <>
                <div class="mt-10 mx-12 collection-default-lang-banner">
                    <TitleAlertBanner title="Content in English" desc="Additional content available in English" />
                </div>
                <div class="collection-grid mt-8 grid justify-items-center grid-cols-1 gap-8 px-4 md:px-10 md:gap-10 md:grid-cols-2 xl:gap-8 xl:grid-cols-3 xl:px-5 max-w-7xl mx-auto">
                    {collection_carddata_defaultlang.map((card) => (
                        <div class="collection-card w-full" data-filtertags={card.data.filtertags?.join(",") || ""}>
                            {card.data.featured && (
                                <CardDefault2 card={card} pathdir={collection_name} pagelang={lang} />
                            )}
                            {!card.data.featured && (
                                <CardInfo card={card} pathdir={collection_name} pagelang={lang} />
                            )}
                        </div>
                    ))}
                </div>
            </>
        )}
    </>
)}

{_props("card") === "blog" && (
    <>
        <div class="collection-grid mt-10 grid justify-items-center items-center gap-10 grid-cols-1 xl:grid-cols-2 xl:px-9 max-w-7xl mx-auto px-4">
            {collection_carddata_actlang.map((card) => (
                <div class="collection-card w-full" data-filtertags={card.data.filtertags?.join(",") || ""}>
                    <CardBlog card={card} pathdir={collection_name} pagelang={lang} />
                </div>
            ))}
        </div>
        {collection_carddata_defaultlang.length > 0 && (
            <>
                <div class="mt-10 mx-12 collection-default-lang-banner">
                    <TitleAlertBanner title="Content in English" />
                </div>
                <div class="collection-grid grid justify-items-center items-center gap-10 grid-cols-1 xl:grid-cols-2 xl:px-9 max-w-7xl mx-auto px-4">
                    {collection_carddata_defaultlang.map((card) => (
                        <div class="collection-card w-full" data-filtertags={card.data.filtertags?.join(",") || ""}>
                            <CardBlog card={card} pathdir={collection_name} pagelang={lang} />
                        </div>
                    ))}
                </div>
            </>
        )}
    </>
)}

{_props("card") === "info" && (
    <>
        <div class="collection-grid mt-12 grid justify-items-center grid-cols-1 gap-8 px-4 md:px-10 md:gap-10 md:grid-cols-2 xl:gap-8 xl:grid-cols-3 xl:px-5 max-w-7xl mx-auto">
            {collection_carddata_actlang.map((card) => (
                <div class="collection-card w-full" data-filtertags={card.data.filtertags?.join(",") || ""}>
                    <CardInfo card={card} pathdir={collection_name} pagelang={lang} />
                </div>
            ))}
        </div>
        {collection_carddata_defaultlang.length > 0 && (
            <>
                <div class="mt-10 mx-12 collection-default-lang-banner">
                    <TitleAlertBanner title="Content in English" />
                </div>
                <div class="collection-grid mt-8 grid justify-items-center grid-cols-1 gap-8 px-4 md:px-10 md:gap-10 md:grid-cols-2 xl:gap-8 xl:grid-cols-3 xl:px-5 max-w-7xl mx-auto">
                    {collection_carddata_defaultlang.map((card) => (
                        <div class="collection-card w-full" data-filtertags={card.data.filtertags?.join(",") || ""}>
                            <CardInfo card={card} pathdir={collection_name} pagelang={lang} />
                        </div>
                    ))}
                </div>
            </>
        )}
    </>
)}

{show_filters && (
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const filterContainer = document.querySelector(".collection-filter");
            if (!filterContainer) return;

            const chips = filterContainer.querySelectorAll<HTMLButtonElement>(".filter-chip");
            const cards = document.querySelectorAll<HTMLElement>(".collection-card");
            const banners = document.querySelectorAll<HTMLElement>(".collection-default-lang-banner");

            chips.forEach((chip) => {
                chip.addEventListener("click", () => {
                    const filter = chip.dataset.filter;

                    // Update active chip
                    chips.forEach((c) => {
                        c.classList.remove("active", "bg-primary", "text-white", "border-primary");
                        c.classList.add("border-border", "text-text-muted");
                    });
                    chip.classList.add("active", "bg-primary", "text-white", "border-primary");
                    chip.classList.remove("border-border", "text-text-muted");

                    // Filter cards
                    let visibleCount = 0;
                    cards.forEach((card) => {
                        const tags = (card.dataset.filtertags || "").split(",");
                        const show = filter === "all" || tags.includes(filter!);
                        card.style.display = show ? "" : "none";
                        if (show) visibleCount++;
                    });

                    // Show/hide default language banners based on visible cards after them
                    banners.forEach((banner) => {
                        const nextGrid = banner.nextElementSibling as HTMLElement;
                        if (nextGrid) {
                            const visibleInGrid = nextGrid.querySelectorAll('.collection-card:not([style*="display: none"])');
                            banner.style.display = visibleInGrid.length > 0 ? "" : "none";
                        }
                    });
                });
            });
        });
    </script>
)}
