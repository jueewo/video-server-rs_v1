---
/**
 * ElementRenderer - Renders page elements from JSON configuration
 *
 * This component has been simplified by extracting:
 * - Scroll effects → ScrollSection.astro
 * - Background logic → SectionBackground.astro
 *
 * This improves performance by only loading the Motion library
 * when scroll effects are actually used.
 */

import Hero from "../../components/page-elements/Hero.astro";
import Hero2 from "../../components/page-elements/Hero2.astro";
import FAQComponent from "../../components/FAQComponent.astro";
import TitleAlertBanner from "../page-elements/TitleAlertBanner.astro";
import TitleHero from "../page-elements/TitleHero.astro";
import AnimateOnView from "../utils/AnimateOnView.astro";
import type { ImageMetadata } from "astro";
import TeamGrid from "../page-elements/TeamGrid.astro";
import StatData from "../../components/page-elements/StatData.astro";
import NewsBanner from "../../components/preact/NewsBanner.tsx";
import MdText from "../../components/page-elements/MdText.astro";
import Carousel from "../page-elements/Carousel.astro";
import SlidingGallery from "../page-elements/SlidingGallery.astro";
import Collection from "../page-elements/Collection.astro";
import DataCTA from "../../components/page-elements/DataCTA.astro";
import DataSurvey from "../../components/page-elements/DataSurvey.astro";
import Hello from "../page-elements/Hello.astro";
import LikeButton from "../preact/LikeButtonRemote";
import Config from "../../website.config.cjs";
import SurveyRemote from "../preact/surveyremote/SurveyRemote";
import Presentation from "../page-elements/Presentation.astro";
import Process from "../page-elements/Process.astro";

// New extracted components
import ScrollSection from "./ScrollSection.astro";
import SectionBackground from "./SectionBackground.astro";
import HlsVideoPlayer from "../HlsVideoPlayer.astro";

const { lang } = Astro.params;
const { element, alt, index } = Astro.props;

let actlang = lang ? lang : "en";

// Helper: read flat field with legacy props/content fallback
const p = (key: string) => element[key] ?? element.props?.[key] ?? element.content?.[key];

// Parse scroll effect configuration from props
const getScrollEffectConfig = (scrollEffect: string) => {
    const config = {
        enabled: !!scrollEffect,
        direction: "left" as "left" | "right",
        speed: "medium" as "slow" | "medium" | "fast",
        type: "horizontal" as const,
    };

    if (!scrollEffect) return config;

    const classes = scrollEffect.split(" ");

    if (classes.includes("scroll-right")) config.direction = "right";
    if (classes.includes("scroll-fast")) config.speed = "fast";
    else if (classes.includes("scroll-slow")) config.speed = "slow";

    return config;
};

const hasScrollEffect = !!(element.scrolleffect ?? element.props?.scrolleffect);
const scrollEffectConfig = getScrollEffectConfig(
    (element.scrolleffect ?? element.props?.scrolleffect) || "",
);
---

{
    !element.draft &&
        (element.element === "Section" ? (
            hasScrollEffect ? (
                // Section with scroll effect - delegated to ScrollSection component
                <ScrollSection
                    config={scrollEffectConfig}
                    bgimage={element.bgimage}
                    bgimage_alt={element.bgimage_alt}
                    parallax={element.parallax}
                    styleclass={element.styleclass ?? element.props?.styleclass}
                    priorityBg={index === 0}
                >
                    {element.elements.map((subelement: any, idx: number) => (
                        <div
                            class={
                                "scroll-item" +
                                (element.parallax ? " w-full" : "")
                            }
                        >
                            <AnimateOnView
                                effect={subelement.anim?.animationeffect}
                            >
                                <Astro.self
                                    element={subelement}
                                    alt={element.alt ?? element.props?.alt}
                                    index={idx}
                                />
                            </AnimateOnView>
                        </div>
                    ))}
                </ScrollSection>
            ) : (
                // Section without scroll effect - regular layout
                <div
                    class={
                        "w-full " +
                        ((element.styleclass ?? element.props?.styleclass) || "") +
                        (element.bgimage ? " relative overflow-hidden" : "") +
                        (element.parallax
                            ? " min-h-screen flex flex-col items-center justify-center"
                            : "")
                    }
                >
                    {/* Background layers */}
                    {element.bgimage && (
                        <SectionBackground
                            bgimage={element.bgimage}
                            bgimage_alt={element.bgimage_alt}
                            parallax={element.parallax}
                            priority={index === 0}
                        />
                    )}

                    {/* Section content */}
                    {element.elements.map((subelement: any, idx: number) => (
                        <div
                            class={
                                "w-full" +
                                (element.bgimage ? " relative z-10" : "") +
                                (element.parallax ? " text-center" : "")
                            }
                        >
                            <AnimateOnView
                                effect={subelement.anim?.animationeffect}
                            >
                                <Astro.self
                                    element={subelement}
                                    alt={element.alt ?? element.props?.alt}
                                    index={idx}
                                />
                            </AnimateOnView>
                        </div>
                    ))}
                </div>
            )
        ) : (
            // Render individual elements with optional animation wrapper
            <AnimateOnView effect={element.anim?.animationeffect}>
                {element.element === "Hero" && (
                    <Hero element={element} index={index} />
                )}

                {element.element === "Hero2" && (
                    <Hero2
                        element={element}
                        index={index}
                        alt={alt}
                        lang={actlang}
                    />
                )}

                {element.element === "TitleHero" && (
                    <TitleHero
                        id={p("id")}
                        title={p("title")}
                        desc={p("desc")}
                        img={p("img")}
                        h1={p("h1") ? true : false}
                        h2={p("h2") ? true : false}
                    />
                )}

                {element.element === "TitleAlertBanner" && (
                    <TitleAlertBanner title={p("title")} />
                )}

                {element.element === "StatData" && (
                    <StatData
                        id={p("id")}
                        dataid={p("dataid")}
                        data={p("data")}
                    />
                )}

                {element.element === "Carousel" && (
                    <Carousel
                        id={p("id")}
                        dataid={p("dataid")}
                        data={p("data")}
                    />
                )}

                {element.element === "Presentation" && (
                    <Presentation element={element} />
                )}

                {element.element === "Process" && <Process element={element} />}

                {element.element === "Video" && (
                    <HlsVideoPlayer
                        id="videoplayer-1"
                        src={p("videoUrl")}
                        title={p("title")}
                        poster={p("posterImage")}
                        fallbackImage={p("fallbackImage")}
                        autoplay={p("autoplay")}
                        loop={p("loop")}
                        width="100%"
                        height="auto"
                    />
                )}

                {element.element === "TeamGrid" && (
                    <>
                        <div class="h-8" />
                        <div class="hidden h-8">{p("title")}</div>
                        <TeamGrid
                            teamdata={p("data")}
                            filtertype={p("filter")}
                        />
                    </>
                )}

                {element.element === "NewsBanner" && (
                    <NewsBanner
                        title={p("title")}
                        desc={p("desc")}
                        showbuttons={false}
                        lang={actlang}
                        client:visible
                    />
                )}

                {element.element === "MdText" && (
                    <MdText element={element} lang={actlang} />
                )}

                {element.element === "Collection" && (
                    <Collection element={element} lang={actlang} />
                )}

                {element.element === "CTA" && <DataCTA element={element} />}

                {element.element === "Survey" && (
                    <DataSurvey element={element} />
                )}

                {element.element === "Hello" && <Hello element={element} />}

                {element.element === "FAQ" && p("faqdata") && (
                    <div class="w-full max-w-3xl mx-auto px-4 py-8">
                        <FAQComponent faqdata={p("faqdata")} />
                    </div>
                )}

                {element.element === "CTARemote" && (
                    <SurveyRemote
                        url={Config.datatool.url}
                        surveyid={p("surveyid")}
                        sourceid={p("sourceid")}
                        title={p("title")}
                        submitbuttontxt={p("send")}
                        thankyoumessage={p("thankyoumessage")}
                        showicon
                        client:only="preact"
                    />
                )}

                {element.element === "LikeButton" && (
                    <LikeButton
                        label="Like"
                        showicon
                        url={
                            p("url") && p("url").length > 0
                                ? p("url")
                                : Config.datatool.url
                        }
                        websiteid={Config.datatool.websiteid}
                        pageid={p("sourceid")}
                        token={Config.datatool.token}
                        client:load
                    />
                )}
            </AnimateOnView>
        ))
}

{
    element.element === "SlidingGallery" && (
        <SlidingGallery id={p("id")} dataid={p("dataid")} />
    )
}
