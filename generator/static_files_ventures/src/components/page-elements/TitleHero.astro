---
import PicFromContent from "../utils/PicFromContent.astro";

const { id, title, desc, desc2, image, img, h1, h2: isH2 } = Astro.props;

const descStr: string = Array.isArray(desc) ? desc.join(' ') : (desc || '');
const desc2Str: string = Array.isArray(desc2) ? desc2.join(' ') : (desc2 || '');
---

<section id={id} class="pt-24 pb-10 px-6 md:px-8 lg:px-12">
    <div class="max-w-5xl mx-auto">
        <div class="flex flex-col lg:flex-row items-start gap-6">
            {(image ?? img) && (
                <div class="flex-shrink-0">
                    <PicFromContent
                        imagePath={image ?? img}
                        altTitle={"image_" + title?.replace(/ /g, '-')}
                        class="w-14 h-14 lg:w-16 lg:h-16 rounded-lg"
                    />
                </div>
            )}
            <div>
                {/* Accent bar */}
                <div class="mb-5 animate-fade-up">
                    <div class="accent-bar"></div>
                </div>

                {h1 ? (
                    <h1 class="text-4xl md:text-5xl font-heading font-bold tracking-[-0.02em] leading-[1.1] text-text animate-fade-up delay-1">
                        {title}
                    </h1>
                ) : isH2 ? (
                    <h2 class="text-3xl md:text-4xl font-heading font-semibold tracking-[-0.02em] leading-[1.15] text-text animate-fade-up delay-1">{title}</h2>
                ) : (
                    <h3 class="text-2xl md:text-3xl font-heading font-semibold tracking-[-0.015em] leading-[1.2] text-text animate-fade-up delay-1">{title}</h3>
                )}

                {descStr && (
                    <p class={`mt-4 text-text-muted leading-relaxed animate-fade-up delay-2 ${h1 ? 'text-lg max-w-2xl' : 'max-w-xl'}`}>
                        <Fragment set:html={descStr} />
                    </p>
                )}
                {desc2Str && (
                    <p class="mt-3 text-text-muted leading-relaxed animate-fade-up delay-3">
                        <Fragment set:html={desc2Str} />
                    </p>
                )}
            </div>
        </div>
    </div>
</section>
