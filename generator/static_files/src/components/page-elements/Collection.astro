//     .filter((a) => !a.data.draft)
//     .sort((a, b) =>
//         b.data.pubDate && a.data.pubDate
//             ? b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
//             : 0,
//     )
//     .sort((a, b) => {
//         if (a.data.featured && !b.data.featured) return -1;
//         if (!a.data.featured && b.data.featured) return 1;
//         return 0;
//     })
//     .sort((a, b) => a.data.draft_content - b.data.draft_content);

// var filter_all_active = element.props.filter_all_active || true;

//.. filter_by_feature .. should it be filtered by featured -> filter_by_feature
//.. if yes, then show filtered or not_filtered -> filter_feature
var filter_by_featured = element.props.filter_by_featured;
var filter_featured = element.props.filter_featured;

//.. filter_by_feature .. should it be filtered by filtertag -> filter_by_filtertag
//.. if yes, then show all with filtertag -> filter_filtertag
var filter_by_filtertag =
    element.props.filter_filtertag && element.props.filter_filtertag.length > 0;
var filter_filtertag = element.props.filter_filtertag;

// var filter_all_active = false;
// var filter_all_active_featured = false;
// var filter_by_filtertag = true;
// var filter_filtertag = "course";

const collection_carddata = (await getCollection(element.props.collection))
    .filter(
        (a) =>
            !a.data.draft &&
            (!filter_by_featured || a.data.featured == filter_featured) &&
            // (filter_featured && !filter_by_featured && !a.data.featured) ||
            (!filter_by_filtertag ||
                (filter_by_filtertag &&
                    a.data.filtertags &&
                    a.data.filtertags.includes(filter_filtertag))),
    )
    .sort((a, b) =>
        b.data.pubDate && a.data.pubDate
            ? b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
            : 0,
    )
    .sort((a, b) => {
        if (a.data.featured && !b.data.featured) return -1;
        if (!a.data.featured && b.data.featured) return 1;
        return 0;
    })
    .sort((a, b) => a.data.draft_content - b.data.draft_content);

const collection_carddata_actlang = collection_carddata.filter(
    (a) => a.id.split("/")[0] == lang,
);
// let collection_carddata_defaultlang = collection_carddata.filter((a) => a.id.split("/")[0] == default_lang);

const show_default_lang = element.props.show_default_lang;
const just_unique = element.props.just_unique;

let collection_carddata_defaultlang = [];
if (show_default_lang) {
    collection_carddata_defaultlang = collection_carddata.filter(
        (a) => a.id.split("/")[0] == default_lang,
    );

    if (just_unique) {
        const actlang_ids = collection_carddata_actlang.map(
            (obj) => obj.id.replace(/\.(md|mdx)$/, "").split("/")[1],
        );
        collection_carddata_defaultlang =
            collection_carddata_defaultlang.filter(
                (a) =>
                    a.id.split("/")[0] == default_lang &&
                    !actlang_ids.includes(a.id.replace(/\.(md|mdx)$/, "").split("/")[1]),
            );
    }
}
---

{/* TITLE */}
{
    element.content.title && element.content.title.length > 0 && (
        <div class="mt-12 text-3xl">{element.content.title}</div>
    )
}

{/* CARD: DEFAULT */}
{
    (!element.props.card || element.props.card === "default") && (
        <>
            <div class="mt-12 grid justify-items-center grid-cols-1 gap-8 md:px-10 md:gap-16 md:grid-cols-2 xl:gap-5 xl:grid-cols-3 xl:px-5 content-center">
                {collection_carddata_actlang.map((card) => (
                    <>
                        {card.data.featured && (
                            <CardDefault2
                                card={card}
                                pathdir={element.props.collection}
                                pagelang={lang}
                            />
                        )}
                        {!card.data.featured && (
                            <CardInfo
                                card={card}
                                pathdir={element.props.collection}
                                pagelang={lang}
                            />
                        )}
                    </>
                ))}
            </div>

            {collection_carddata_defaultlang.length > 0 && (
                <>
                    <div class="mt-10 mx-12">
                        <TitleAlertBanner
                            title="Content in English"
                            desc="Additional content just available in English"
                            h2
                        />
                    </div>

                    <div class="mt-12 grid justify-items-center grid-cols-1 gap-8 md:px-10 md:gap-16 md:grid-cols-2 xl:gap-5 xl:grid-cols-3 xl:px-5 content-center">
                        {collection_carddata_defaultlang.map((card) => (
                            <>
                                {card.data.featured && (
                                    <CardDefault2
                                        card={card}
                                        pathdir={element.props.collection}
                                        pagelang={lang}
                                    />
                                )}
                                {!card.data.featured && (
                                    <CardInfo
                                        card={card}
                                        pathdir={element.props.collection}
                                        pagelang={lang}
                                    />
                                )}
                            </>
                        ))}
                    </div>
                </>
            )}
        </>
    )
}

{/* CARD: BLOG */}
{
    element.props.card === "blog" && (
        <>
            <div class="grid justify-items items-center gap-16 grid-cols-1 xl:grid-cols-2 xl:px-9 content-center">
                {collection_carddata_actlang.map((card) => (
                    <div class="bg-slate-900 text-white mx-5 xl:mx-0 rounded-xl">
                        <CardBlog
                            card={card}
                            pathdir={element.props.collection}
                            pagelang={lang}
                        />
                        {/* <CardDefault card={card} pathdir={`${lang}`+"/blog"} /> */}
                    </div>
                ))}
            </div>

            {collection_carddata_defaultlang.length > 0 && (
                <>
                    <div class="mt-10 mx-12">
                        <TitleAlertBanner
                            title="Content in English"
                            desc="Additional content just available in English"
                            h2
                        />
                    </div>

                    <div class="grid justify-items items-center gap-16 grid-cols-1 xl:grid-cols-2 xl:px-9 content-center">
                        {collection_carddata_defaultlang.map((card) => (
                            <div class="bg-slate-900 text-white mx-5 xl:mx-0 rounded-xl">
                                <CardBlog
                                    card={card}
                                    pathdir={element.props.collection}
                                    pagelang={lang}
                                />
                                {/* <CardDefault card={card} pathdir={`${lang}`+"/blog"} /> */}
                            </div>
                        ))}
                    </div>
                </>
            )}
        </>
    )
}

{/* CARD: INFO */}
{
    element.props.card === "info" && (
        <>
            <div class="mt-12 grid justify-items-center grid-cols-1 gap-8 px-4 sm:px-6 md:px-10 md:gap-12 md:grid-cols-2 xl:gap-8 xl:grid-cols-3 xl:px-5 content-center">
                {collection_carddata_actlang.map((card) => (
                    <CardInfo
                        card={card}
                        pathdir={element.props.collection}
                        pagelang={lang}
                    />
                ))}
            </div>

            {collection_carddata_defaultlang.length > 0 && (
                <>
                    <div class="mt-10 mx-12">
                        <TitleAlertBanner
                            title="Content in English"
                            desc="Additional content just available in English"
                            h2
                        />
                    </div>

                    <div class="mt-12 grid justify-items-center grid-cols-1 gap-8 px-4 sm:px-6 md:px-10 md:gap-12 md:grid-cols-2 xl:gap-8 xl:grid-cols-3 xl:px-5 content-center">
                        {collection_carddata_defaultlang.map((card) => (
                            <CardInfo
                                card={card}
                                pathdir={element.props.collection}
                                pagelang={lang}
                            />
                        ))}
                    </div>
                </>
            )}
        </>
    )
}
