---
import type { CollectionEntry } from "astro:content";

import { Image } from "astro:assets";
import { b } from '../utils/siteBase';
import CardDraftOverlay from "./CardDraftOverlay.astro";

interface Props {
    card: CollectionEntry;
    pathdir: String;
    pagelang?: String;
    showimage?: boolean;
}
const { card, pathdir, pagelang, showimage = true } = Astro.props;

let [contentlang, slug] = card.id.replace(/\.(md|mdx)$/, "").split("/");
if (!slug) ((slug = contentlang), (contentlang = "en"));
//.. FALLBACK if not i18n, no language ('/en/post1.md' vs '/post1.md')

// Use page language if provided, otherwise fall back to content language
const lang = pagelang || contentlang;

const hasImage = showimage && card.data.image;
---

{/* CARDINFO */}
<a
    href={(!card.data.draft_content || card.data.draft_content_clickable) &&
    (!card.data.url || card.data.url.length == 0)
        ? `${b}${lang}/${pathdir}/${slug}`
        : card.data.url}
    class="block w-full"
>
    <div class="w-full max-w-full">
        <div
            class="card relative w-full max-w-sm mx-auto sm:max-w-md md:max-w-sm lg:max-w-md bg-base-100 shadow-xl overflow-hidden"
        >
            {
                hasImage ? (
                    <figure class="aspect-[4/3] overflow-hidden">
                        <Image
                            src={card.data.image}
                            alt={card.data.title}
                            class="w-full h-full object-cover"
                            widths={[320, 640, 960]}
                            format="webp"
                            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 384px"
                            quality={80}
                        />
                    </figure>
                ) : (
                    <div class="aspect-[4/3] bg-gradient-to-br from-base-200 to-base-300 flex items-center justify-center">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="w-16 h-16 text-base-content/30"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"
                            />
                        </svg>
                    </div>
                )
            }

            {/* Content overlay */}
            <div
                class="absolute h-1/2 bottom-0 left-0 right-0 bg-black/80 text-white"
            >
                <div class="card-body relative h-full p-4">
                    <span class="flex items-center gap-2">
                        <h2
                            class="card-title flex-auto text-base sm:text-lg line-clamp-2"
                        >
                            {card.data.title}
                        </h2>
                        {
                            card.data.badge && card.data.badge.length > 0 && (
                                <div class="flex-shrink-0 bg-warning p-1 flex justify-center rounded">
                                    <div class="text-center text-xs text-warning-content">
                                        {card.data.badge}
                                    </div>
                                </div>
                            )
                        }
                    </span>
                    <p class="text-sm line-clamp-2 opacity-90">
                        {card.data.desc}
                    </p>
                    <div
                        class="mt-auto card-actions justify-start flex-wrap gap-1"
                    >
                        {
                            card.data.typetags &&
                                card.data.typetags.length > 0 &&
                                card.data.typetags.map((tag: string) => (
                                    <div class="badge badge-sm badge-primary">
                                        #{tag}
                                    </div>
                                ))
                        }
                        {
                            card.data.tags &&
                                card.data.tags.length > 0 &&
                                card.data.tags
                                    .slice(0, 3)
                                    .map((tag: string) => (
                                        <div class="badge badge-sm badge-outline">
                                            {tag}
                                        </div>
                                    ))
                        }
                    </div>
                </div>
            </div>

            {/* Content message badge */}
            {
                card.data.content_msg && (
                    <div class="absolute top-0 left-0 right-0 p-2">
                        <span class="badge badge-warning">
                            {card.data.content_msg}
                        </span>
                    </div>
                )
            }

            {/* Overlay for draft content */}
            {
                card.data.draft_content && (
                    <div class="absolute inset-0">
                        <CardDraftOverlay card={card} />
                    </div>
                )
            }
        </div>
    </div>
</a>
