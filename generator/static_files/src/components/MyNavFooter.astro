---
// import SocialMediaIcon from "./SocialMediaIcon.vue";
import SocialMedia from "./SocialMedia.astro";
import Config from "../website.config.cjs";

import { Image, imageConfig } from "astro:assets";
// import Logo from "./Logo.astro";

const {
    sitename,
    showlogo,
    footerLogo, //..new
    social,
    legal,
    footerNavigationMenu,
    footerContent,
    extprop,
} = Astro.props;

const { lang } = Astro.params;

import { getRelativeLocaleUrl } from "astro:i18n";
import { b } from '../utils/siteBase';
import { t } from '../utils/localize';

// const preferredLocale = Astro.preferredLocale;
// const preferredLocales = Astro.preferredLocaleList;
---

<div
    id="footer"
    class="w-full relative bg-base-200 z-20 mt-16"
>
    <svg
        class="absolute top-0 w-full h-6 -mt-5 sm:-mt-10 sm:h-16 text-base-200 bg-transparent"
        preserveAspectRatio="none"
        viewBox="0 0 1440 54"
    >
        <path
            fill="currentColor"
            d="M0 22L120 16.7C240 11 480 1.00001 720 0.700012C960 1.00001 1200 11 1320 16.7L1440 22V54H1320C1200 54 960 54 720 54C480 54 240 54 120 54H0V22Z"
        ></path>
    </svg>
    <div
        class="px-4 pt-12 mx-auto sm:max-w-xl md:max-w-full lg:max-w-screen-xl md:px-24 lg:px-8"
    >
        <div class="grid gap-16 row-gap-10 mb-8 lg:grid-cols-6">
            <div class="md:max-w-md lg:col-span-2">
                <a
                    href={lang ? `${b}/${lang}/home` : `${b}/home`}
                    aria-label="Go home"
                    title="Company"
                    class="inline-flex items-center"
                >
                    {
                        footerContent && showlogo && footerLogo && (
                            <div class="logo-wrapper">
                                <div class="logo-inner w-14 h-14">
                                    {/* <img src={`/` + footerContent.logo} /> */}
                                    <Image src={footerLogo} alt="logo" />
                                </div>
                            </div>
                        )
                    }

                    <span
                        class="ml-2 text-xl font-bold tracking-wide text-base-content uppercase"
                    >
                        {sitename}
                    </span>
                </a>

                <div class="mt-4 lg:max-w-sm">
                    <p class="text-sm text-base-content/80">
                        <Fragment set:html={footerContent.text} />
                    </p>
                </div>
            </div>

            <div
                class="grid grid-cols-2 gap-5 row-gap-8 lg:col-span-4 md:grid-cols-4"
            >
                {
                    footerNavigationMenu &&
                        footerNavigationMenu.map((category) => (
                            <div>
                                <p class="font-semibold tracking-wide text-base-content">
                                    {category.link ? (
                                        <span>
                                            <a
                                                href={
                                                    category.external || category.link.startsWith("http")
                                                        ? category.link
                                                        : lang
                                                            ? `${b}/${lang}${category.link}`
                                                            : category.link
                                                }
                                                class="transition-colors duration-300 text-base-content hover:text-primary hover:underline"
                                                {...(category.external || category.link.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                                            >
                                                {t(category.header, lang)}
                                            </a>
                                        </span>
                                    ) : (
                                        <span>{t(category.header, lang)}</span>
                                    )}
                                </p>
                                <ul class="mt-2 space-y-2">
                                    {category.links &&
                                        category.links.map((link) => (
                                            <li>
                                                {link.link &&
                                                link.link.length > 0 ? (
                                                    <a
                                                        href={
                                                            link.external || link.link.startsWith("http")
                                                                ? link.link
                                                                : lang
                                                                    ? `${b}/${lang}${link.link}`
                                                                    : link.link
                                                        }
                                                        class="transition-colors duration-300 text-base-content hover:text-primary"
                                                        {...(link.external || link.link.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                                                    >
                                                        <span class="hover:underline">
                                                            {t(link.name, lang)}{" "}
                                                            {/* {link.link} */}
                                                        </span>
                                                        {link.external && (
                                                            <span class="text-xs ml-1">
                                                                {" "}
                                                                ↗{" "}
                                                            </span>
                                                        )}
                                                    </a>
                                                ) : (
                                                    <span class="text-base-content/60">
                                                        {t(link.name, lang)}
                                                    </span>
                                                )}
                                            </li>
                                        ))}
                                </ul>
                            </div>
                        ))
                }
            </div>
        </div>
    </div>
    <!--SECOND -->
    <div
        class="flex flex-col justify-between p-5 pb-10 border-t border-deep-purple-accent-200 sm:flex-row"
    >
        <p class="flex items-center px-5">
            <span class="text-sm text-base-content/80">
                {
                    footerContent && (
                        <Fragment
                            set:html={`&copy; ${footerContent.copyright}`}
                        />
                    )
                }

                {
                    extprop && extprop.length > 0 && (
                        <>
                            <span class="mx-2">|</span>
                            <Fragment set:html={extprop} />
                        </>
                    )
                }
            </span>
        </p>

        <SocialMedia
            socialMedia={Config.socialMedia}
            baseURL={Config.baseURL}
        />

        <!-- LEGAL LINKS -->

        <div class="flex items-center mt-4 px-5 space-x-4 sm:mt-0">
            {
                legal &&
                    legal.map((legalitem) => (
                        <span>
                            <a
                                class="text-base-content/80 text-sm"
                                href={
                                    lang
                                        ? `${b}/${lang}/${legalitem.collection}${legalitem.link}`
                                        : legalitem.link
                                }
                            >
                                {t(legalitem.name, lang)}
                            </a>
                        </span>
                    ))
            }
        </div>
    </div>
</div>
