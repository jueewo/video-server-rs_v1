# ============================================================
# Media Server — Docker deployment environment
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# Domains (used by Caddy for automatic HTTPS)
# ------------------------------------------------------------
DOMAIN=app.example.com
AUTH_DOMAIN=auth.example.com

# ------------------------------------------------------------
# OIDC — Casdoor application credentials
# Get these from Casdoor after creating an Application:
#   https://auth.example.com → Applications → your app → Client ID / Secret
# ------------------------------------------------------------
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ------------------------------------------------------------
# Platform admin
# Your Casdoor user UUID — visible at /profile under "User ID"
# ------------------------------------------------------------
PLATFORM_ADMIN_ID=

# ------------------------------------------------------------
# Grafana
# ------------------------------------------------------------
GRAFANA_PASSWORD=changeme

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
RUST_LOG=info
RUN_MODE=production

# ------------------------------------------------------------
# Emergency login — for initial setup only, disable in production
# ------------------------------------------------------------
# ENABLE_EMERGENCY_LOGIN=true
# SU_USER=admin
# SU_PWD=changeme
