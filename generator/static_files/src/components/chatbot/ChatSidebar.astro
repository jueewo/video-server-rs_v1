---
// import NewsBannerMenu from "../components/NewsBannerMenu.vue";
// import ChatBotDemo from "./ChatBotDemo.vue";
// import ChatBot from "./ChatBotAlpha.vue";
import ChatBot from "./ChatBotAlpha.tsx";

import { Image } from "astro:assets";
// import { ChatbotImage } from "/src/assets/images/chatbot/profile/profile_robot_3.jpg";
// import chatbotImage from "../../assets/images/chatbot/profile/profile_robot_3.jpg";
import chatbotImage from "../../assets/images/team/profile_robot_3.jpg";
---

<div>
    <div id="my-drawer" class="drawer drawer-end z-10">
        <input id="my-drawer-chat" type="checkbox" class="drawer-toggle" />
        <div class="">
            <div @click="connectws()" id="chatavatar" class="drawer-button">
                <label for="my-drawer-chat" class="">
                    <div class="avatar online">
                        <div class="w-16 rounded-full">
                            <!-- <img src="/images/team/profile_robot_5.jpg" /> -->
                            <!-- <img src="/images/chatbot/profile/profile_robot_3.jpg" /> -->
                            <!-- <Image src="../../../assets/images/chatbot/profile/profile_robot_3.jpg" alt="Chatbot" width="50" height="50"  /> -->
                            <Image src={chatbotImage} alt="Chatbot" />
                        </div>
                    </div>
                </label>
            </div>
        </div>

        <div class="drawer-side z-30">
            <label for="my-drawer-chat" class="drawer-overlay"></label>
            <ul
                class="z-10 w-80 md:w-96 overflow-y-auto bg-base-100 text-base-content"
            >
                <!-- Sidebar content here -->

                <!-- CLOSE BUTTON  -->
                <label
                    for="my-drawer-chat"
                    class="z-40 btn btn-circle btn-secondary absolute right-2 top-2"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.5"
                        stroke="currentColor"
                        class="w-6 h-6"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </label>

                <ChatBot client:visible />

                <!-- <ChatBotDemo client:visible /> -->
            </ul>
        </div>

        <style>
            #chatavatar {
                position: fixed;
                right: 1em;
                bottom: 1em;
                /* height: 6rem; */
                /* width: 6rem; */
                /* margin: 0; */
                /* padding: 0; */
                z-index: 40;
                /* background-color: red; */
            }

            #my-drawer {
            }
        </style>
    </div>
</div>
