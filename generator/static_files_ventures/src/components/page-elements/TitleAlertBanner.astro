---
const { title, desc, h2 } = Astro.props;
---

<div class="py-4 px-6 bg-accent/10 border border-accent/20 rounded-xl text-center">
    {h2 ? (
        <h2 class="text-lg font-semibold text-accent-dark font-heading">{title}</h2>
    ) : (
        <h3 class="text-lg font-semibold text-accent-dark font-heading">{title}</h3>
    )}
    {desc && <p class="text-sm text-text-muted mt-1">{desc}</p>}
</div>
