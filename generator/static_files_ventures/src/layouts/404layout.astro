---
import "../styles/global.css";

import Config from "../website.config.cjs";

const { lang } = Astro.params;
---

<html lang={lang ? lang : "en"}>
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=5"
        />

        <link rel="icon" type="image/x-icon" href={Config.favicon} />

        <meta name="apple-mobile-web-app-title" content={Config.siteTitle} />
        <link rel="apple-touch-icon" href={Config.siteLogoIcon} />
        <slot name="head" />

        <script is:inline>
            // Theme initialization - prevent flash of wrong theme
            (function() {
                var saved = localStorage.getItem("theme");
                if (saved === "dark") {
                    document.documentElement.classList.add("dark");
                } else if (!saved) {
                    if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
                        document.documentElement.classList.add("dark");
                        localStorage.setItem("theme", "dark");
                    } else {
                        localStorage.setItem("theme", "light");
                    }
                }
            })();
        </script>
    </head>
    <body class="min-h-screen bg-surface text-text">
        <div class="flex items-center justify-center min-h-[80vh]">
            <div class="text-center px-6">
                <div class="prose py-16 mx-5 md:mx-12">
                    <slot />
                </div>
            </div>
        </div>
    </body>
</html>
