---
import PicFromContent from "../utils/PicFromContent.astro";

const { teamdata, filtertype } = Astro.props;

const filteredTeam = filtertype
    ? teamdata?.filter((member: any) => member.type === filtertype || !member.type)
    : teamdata;
---

{filteredTeam && filteredTeam.length > 0 && (
    <section class="py-12 px-4">
        <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {filteredTeam.map((member: any) => (
                <div class="card-theme p-6 text-center group">
                    {member.image && (
                        <div class="w-24 h-24 mx-auto mb-4 rounded-full overflow-hidden ring-2 ring-border group-hover:ring-primary transition-colors">
                            <PicFromContent
                                imagePath={member.image}
                                altTitle={member.name}
                                class="w-full h-full [&_img]:w-full [&_img]:h-full [&_img]:object-cover"
                                quality={80}
                            />
                        </div>
                    )}
                    <h3 class="font-heading font-bold text-lg text-text">{member.name}</h3>
                    {member.role && <p class="text-sm text-text-muted mt-1">{member.role}</p>}
                    {member.desc && <p class="text-sm text-text-subtle mt-2">{member.desc}</p>}
                    {member.links && (
                        <div class="flex justify-center gap-3 mt-4">
                            {member.links.map((link: any) => (
                                <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition-colors text-sm">
                                    {link.label || link.name}
                                </a>
                            ))}
                        </div>
                    )}
                </div>
            ))}
        </div>
    </section>
)}
