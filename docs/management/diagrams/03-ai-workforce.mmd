            T3["workspace_list_files"]
            T4["workspace_search"]
            T5["folder_structure"]
            T6["workspace_context"]
        end
        TOOLS --> VAL["🔒 Path Validation<br/><small>Scoped to workspace root</small>"]
    end

    subgraph PROVIDERS["LLM Providers (BYOK)"]
        direction LR
        P1["Anthropic<br/><small>Claude</small>"]
        P2["OpenAI<br/><small>GPT-4</small>"]
        P3["Ollama<br/><small>Local models</small>"]
        P4["Custom<br/><small>Any OpenAI-compatible</small>"]
