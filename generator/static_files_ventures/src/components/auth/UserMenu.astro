---
import ThemeToggle from "../utils/ThemeToggle.astro";
import ModalComponent from "../utils/ModalComponent.astro";
import { Image } from "astro:assets";
import userProfilePic from "../../assets/images/team/profile_jw2.jpg";
import userPlaceholderPic from "../../assets/images/utils/placeholder-about.jpg";
import SurveyRemote from "../preact/surveyremote/SurveyRemote";
import Config from "../../website.config.cjs";

const session = null;
---

<div class="relative">
  <button id="user-menu-btn" class="p-1 rounded-full overflow-hidden focus:outline-none focus:ring-2 focus:ring-primary/50">
    <div class="w-10 h-10 rounded-full overflow-hidden">
      {
        session ? (
          <Image src={userProfilePic} alt="User Profile" class="w-full h-full object-cover" />
        ) : (
          <Image src={userPlaceholderPic} alt="User Placeholder" class="w-full h-full object-cover" />
        )
      }
    </div>
  </button>
  <div
    id="user-menu-dropdown"
    class="hidden absolute right-0 top-full mt-2 z-40 p-2 shadow-xl bg-surface border border-border rounded-xl w-52"
  >
    <ul class="space-y-1">
      {
        session ? (
          <>
            <li>
              <a href="/auth/profile" class="flex items-center justify-between px-3 py-2 rounded-md text-base hover:bg-surface-alt transition-colors text-text">
                Profile
                <span class="tag-ventures bg-primary/10 text-primary text-xs">New</span>
              </a>
            </li>
            <li>
              <form method="post" action="/auth/logout">
                <input class="w-full text-left px-3 py-2 rounded-md text-base hover:bg-surface-alt transition-colors text-text cursor-pointer" type="submit" value="Sign out" />
              </form>
            </li>
            <li>
              <hr class="my-2 border-border" />
            </li>
            <li>
              <a href="/admin" class="block px-3 py-2 rounded-md text-base hover:bg-surface-alt transition-colors text-text">
                Admin
              </a>
            </li>
          </>
        ) : (
          <li>
            <a href="/auth/login" class="block px-3 py-2 rounded-md text-base hover:bg-surface-alt transition-colors text-text">
              Login
            </a>
          </li>
        )
      }

      <li class="pt-2 border-t border-border mt-2">
        <ThemeToggle />
      </li>
    </ul>
  </div>
</div>

<script>
  const btn = document.getElementById("user-menu-btn");
  const dropdown = document.getElementById("user-menu-dropdown");

  btn?.addEventListener("click", (e) => {
    e.stopPropagation();
    dropdown?.classList.toggle("hidden");
  });

  document.addEventListener("click", (e) => {
    if (!dropdown?.contains(e.target as Node) && e.target !== btn) {
      dropdown?.classList.add("hidden");
    }
  });
</script>
