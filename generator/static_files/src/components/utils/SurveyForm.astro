<!-- <Layout title={surveyid}> -->
<div class={fullpage ? 'min-h-screen flex flex-col justify-center items-center' : 'flex flex-col justify-center items-center'}>



{surveydef ? 
(
  <!-- 
    <ul class="steps">
      <li class="nav-item step step-primary active" data-target="Register">Register</li>
      <li class="nav-item step" data-target="Plan">Plan</li>
      <li class="nav-item step" data-target="Purchase">Purchase</li>
      <li class="nav-item step" data-target="Product">Product</li>
    </ul>

    <div id="panels" class="mt-8">
      <div class=" Register panel active">PANEL1</div>
      <div class=" Plan panel">PANEL2</div>
      <div class=" Purchase panel">PANEL3</div>
      <div class=" Product panel">PANEL4</div>
    </div> 
  -->
  

    <!-- <div class="  flex-col justify-center items-center overflow-visible"> -->
    <!-- {{ props.fullpage }} / {{ isfullpage }} / {{ addons }} -->
    
    <div class="w-96 p-6 m-auto rounded-md shadow-md lg:max-w-lg">
      <h1 class="text-3xl font-semibold text-center text-primary">
        { title_override ?
          <span>
            { title_override }
          </span> :
          <span>
            { surveydef.title }
          </span>
        }
        
        
      </h1>
      { desc_override && <p>{ desc_override }</p> }

      

      <form method="POST" id="myform" enctype="multipart/form-data" class="w-80 space-y-4">
        <input type="text" hidden name="source" value={id} />
        <input type="text" hidden name="surveyid" value={surveydef.id} />

        

        
        { surveydef.hiddenfield && surveydef.hiddenfield.length > 0 && 
          <div>
            <label class="label hidden">
              <span class="text-base label-text">{ surveydef.hiddenfield }</span>
            </label>
            <input
              type="text"
              id={surveydef.hiddenfield}
              name={surveydef.hiddenfield}
              placeholder={surveydef.hiddenfield}
            
              class="w-full input input-bordered input-primary"
              hidden
            />
          </div>
        }

        <ul class="steps">
          { surveydef.pages.length>0 && surveydef.pages.map((page, index) => (
            <li class={index == 0 ? 'nav-item step step-primary active': 'nav-item step'} data-target={page.label}>{page.label}</li>
          ))}
          <li class='nav-item step' data-target="FINAL">FINAL</li>
        </ul>

        
        <div id="panels" class="mt-8">
          { surveydef.pages.length>0 && surveydef.pages.map((page, index) => (
            <div class={index == 0 ? `${page.label} panel active` : `${page.label} panel`}>{page.label}</div>
          ))}
          <div class="FINAL panel">FINAL</div>
          
        </div>
          
       

        <div id="pages">
        { surveydef.pages.length>0 && surveydef.pages.map((page, index) => (
          <div class={index == 0 ? `${page.label} page active` : `${page.label} page`}> 

            <!-- 
              {JSON.stringify(page)}
            -->

            { page.fields.map((field) => 
              <div class="field">
                { field.element === 'input' && 
                <div>
                  
                  { field.type !== 'checkbox'  && field.type !== 'range' && field.type !== 'file' && 
                  <span>
                    <label class="label">
                      <span class="text-base label-text">{ field.title }</span>
                    </label>
                    
                    <input
                      type={field.type}
                      id={field.id}
                      name={field.name}
                      required={field.required ? true : false}
                      placeholder={field.placeholder}
                      class="w-full input input-bordered input-primary"
                    />
                  </span>
                  }

                  { field.type === 'range' && 
                  <span>
                    <label class="label">
                      <span class="text-base label-text flex items-center">{ field.title }
                        <div
                          class="tooltip tooltip-top"
                          data-tip={field.placeholder}
                        >
                          
                          <IconInfo w="w-8" h="h-8" classparam="w-8 h-8" />
                        </div>  
                      </span>
                    </label>
                    
                    <input
                      type={field.type}
                      id={field.id}
                      name={field.name}
                      required={field.required ? true : false}
                      placeholder={field.placeholder}
                      class="range range-primary"
                      min="0" max="10" step="1" value="2"
                    />
                    <div class="w-full flex justify-between text-xs px-2">
                      { [...Array(11).keys()].map((nr) => <span>|</span>)}
                      
                    </div>
                    
                  </span>
                  }

                  { field.type === 'checkbox' && 
                  <span>
                    <div class="form-control">
                      <label class="label cursor-pointer">
                        <span class="label-text flex items-center"
                          >{ field.title }
                          <div
                            class="tooltip tooltip-top"
                            data-tip={field.placeholder}
                          >
                            
                            <IconInfo w="w-8" h="h-8" classparam="w-8 h-8" />
                          </div>
                        </span>
                        
                        <input
                          type={field.type}
                          id={field.id}
                          name={field.name}
                          required={field.required ? true : false}
                          
                          class="checkbox"
                        />
                      </label>
                    </div>
                  </span>
                  }

                  { field.type === 'file' && 
                  <span>
                    <div class="form-control">
                      <label class="label cursor-pointer">
                        <span class="label-text flex items-center"
                          >{ field.title }
                          <div
                            class="tooltip tooltip-top"
                            data-tip={field.placeholder}
                          >
                            
                            <IconInfo w="w-8" h="h-8" classparam="w-8 h-8" />
                          </div>
                        </span>
                        
                        <input
                          type={field.type}
                          id={field.id}
                          name={field.name}
                          required={field.required ? true : false}
                          mulitple
                          class="fileupload"
                        />
                      </label>
                    </div>
                  </span>
                  }

                </div>
                }

                
                { field.element == 'textarea' && 
                <div>
                  <label class="label">
                    <span class="text-base label-text">{ field.title }</span>
                  </label>
                  <textarea
                    id={field.id}
                    name={field.name}
                    required={field.required ? true : false}
                    placeholder={field.placeholder}
                  
                    class="w-full h-24 input input-bordered input-primary"
                  />
                </div> 
                } 
              </div>  
              )
            }  

          
          </div>))  
        }
        


          <div class="FINAL page">
            <div class="flex flex-col items-center">
              <button data-send-button class="btn btn-primary">{ surveydef.buttontxt }</button>
            </div>
            
            <div class="text-xs mt-8">
              By clicking `{ surveydef.buttontxt }`, you agree to our
              <a
                href="/info/privacy"
                class="text-xs text-gray-600 underline hover:underline hover:text-blue-600"
              >
                Privacy Policy
              </a>
            </div>
          </div>

        </div>

        
        <div class="flex items-center justify-center">
          <div id="backbtn" class="btn btn-sm btn-primary" >PREV</div>
          <div id="nextbtn" class="btn btn-sm btn-primary" >NEXT</div>
        </div>

        <div class="" id="validation_message"></div>

      </form>
      
      

      
      { responseMessage && responseMessage.msg && 
      <div class="alert alert-success mt-12">
        <span>{ responseMessage.msg }</span>
      </div>
      }
    </div>
  <!-- </div> -->

  ) : "SURVEY NOT FOUND"}
</div>

<!-- </Layout> -->