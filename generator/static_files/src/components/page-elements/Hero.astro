---
// Hero component - PERFORMANCE OPTIMIZED
// - Lazy loading for below-the-fold images
// - Priority loading for first hero (index === 0)
// - Responsive image sizes for mobile optimization

const { element, alt, index } = Astro.props;
// alt: change left/right (pic and text order)
// index: required if alt, also used to determine priority loading

const { lang } = Astro.params;

// -- IMAGES --
import PicFromContent from "../utils/PicFromContent.astro";
import { b } from '../../utils/siteBase';

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import placeholderImage from "../../assets/images/utils/placeholder-hero-square.jpg";

const images = await import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/images/logos/*.{jpeg,jpg,png,gif,svg,webp}",
);

const getImage = (imagePath: string) => {
    const prefix = "/src/assets";
    if (!images[prefix + imagePath]) return placeholderImage;
    return images[prefix + imagePath]();
};

// First hero (index 0) gets priority loading for LCP optimization
const isFirstHero = index === 0 || index === undefined;

// Flat structure with legacy props/content fallback
const fullscreen  = element.fullscreen  ?? element.props?.fullscreen;
const image_zoomable = element.image_zoomable ?? element.props?.image_zoomable;
const ext         = element.ext         ?? element.props?.ext;
const rawLink     = element.link        ?? element.props?.link;
const image       = element.image       ?? element.content?.image;
const title       = element.title       ?? element.content?.title ?? "";
const desc        = element.desc        ?? element.content?.desc;
const button      = element.button      ?? element.content?.button;

// Handle link as string or object with path property
const linkUrl =
    typeof rawLink === "string"
        ? rawLink
        : rawLink?.path || "";

const is_external_link =
    linkUrl.includes("http") ||
    linkUrl.includes("https") ||
    linkUrl.includes("www");

---

<div
    class={(fullscreen ? "min-h-screen " : "") +
        " bg-base-100 my-12 p-4 md:p-12 lg:w-full"}
>
    <div class="p-2 md:p-4 xl:p-8 m-auto">
        {
            image && (
                <PicFromContent
                    imagePath={image}
                    altTitle={"image_" + title.replace(/ /g, "-")}
                    class="w-3/4 lg:max-w-xl m-auto rounded-lg"
                    priority={isFirstHero}
                    sizes="(max-width: 640px) 75vw, (max-width: 1024px) 50vw, 576px"
                    quality={80}
                />
            )
        }

        {
            image_zoomable && (
                <div class="flex justify-end items-center">
                    <button
                        class="btn btn-ghost"
                        onclick={`document.getElementById('zoom_modal_${index}').showModal()`}
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="size-6"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6"
                            />
                        </svg>
                    </button>

                    <dialog
                        id={"zoom_modal_" + index}
                        class="modal modal-bottom sm:modal-middle"
                    >
                        <div class="modal-box w-full sm:w-11/12">
                            {image && (
                                <Image
                                    src={getImage(image)}
                                    alt={"image_" + title.replace(/ /g, "-")}
                                    class="w-fill m-auto rounded-lg"
                                    loading="lazy"
                                    decoding="async"
                                    format="webp"
                                    quality={80}
                                />
                            )}

                            <div class="modal-action">
                                <form method="dialog">
                                    <button class="btn btn-xs">Close</button>
                                    <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">
                                        ✕
                                    </button>
                                </form>
                            </div>
                        </div>
                    </dialog>
                </div>
            )
        }
    </div>

    <div class="max-w-md m-auto text-center">
        <h1 class="pt-4 mb-5 text-2xl font-bold">
            <Fragment set:html={title} />
        </h1>

        {
            desc &&
                (Array.isArray(desc) ? desc : [desc]).map((line: string) => (
                    <p class="pt-6">
                        <Fragment set:html={line} />
                    </p>
                ))
        }

        {
            linkUrl && (
                <div>
                    {ext ? (
                        <a href={linkUrl} target="_blank">
                            <button class="btn btn-outline my-6">
                                {button}
                                <span class="text-xs ml-1"> ↗ </span>
                                <span class="text-xs ml-1">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor"
                                        class="w-6 h-6"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M8.25 4.5l7.5 7.5-7.5 7.5"
                                        />
                                    </svg>
                                </span>
                            </button>
                        </a>
                    ) : (
                        <a href={b + "/" + lang + linkUrl}>
                            <button class="btn btn-outline my-6">
                                {button}
                                <span class="text-xs ml-1">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke-width="1.5"
                                        stroke="currentColor"
                                        class="w-6 h-6"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M8.25 4.5l7.5 7.5-7.5 7.5"
                                        />
                                    </svg>
                                </span>
                            </button>
                        </a>
                    )}
                </div>
            )
        }
    </div>
</div>
